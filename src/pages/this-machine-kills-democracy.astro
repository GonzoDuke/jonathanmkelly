---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import ThisMachineKillsDemocracy from '../components/pieces/poems/ThisMachineKillsDemocracy.jsx';

const piece = PIECES.find(p => p.id === 'this-machine-kills-democracy');
---

<PieceLayout piece={piece}>
  <ThisMachineKillsDemocracy client:load />
</PieceLayout>
