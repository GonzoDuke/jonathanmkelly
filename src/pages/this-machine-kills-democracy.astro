---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parseThisMachine, overprintTokens } from '../data/poems/this-machine-kills-democracy.js';

const stanzas = parseThisMachine();
const year = '2024';
const next = { slug: 'kerouac-is-chilling-on-my-couch', title: 'Kerouac is Chilling on My Couch' };

// Four-line stacked title: each word on its own line so the Courier Prime
// banner reads as hammered-out manifesto type, one strike per word.
const titleWords = ['This', 'Machine', 'Kills', 'Democracy'];
---
<PoetryLayout
  title="This Machine Kills Democracy — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/this-machine-kills-democracy"
>
  <div class="tm-page">
    <svg class="tm-grain" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="tm-grain-fine">
          <feTurbulence type="fractalNoise" baseFrequency="0.92" numOctaves="2" seed="11" stitchTiles="stitch" />
          <feColorMatrix values="0 0 0 0 0.22  0 0 0 0 0.15  0 0 0 0 0.09  0 0 0 0.55 0" />
        </filter>
        <filter id="tm-grain-coarse">
          <feTurbulence type="fractalNoise" baseFrequency="0.18" numOctaves="2" seed="7" stitchTiles="stitch" />
          <feColorMatrix values="0 0 0 0 0.36  0 0 0 0 0.26  0 0 0 0 0.14  0 0 0 0.32 0" />
        </filter>
      </defs>
      <rect width="100%" height="100%" filter="url(#tm-grain-coarse)" />
      <rect width="100%" height="100%" filter="url(#tm-grain-fine)" />
    </svg>

    <nav class="tm-nav">
      <a href="/" class="tm-brand">JMK</a>
      <div class="tm-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="tm-article">
      <a href="/poetry" class="tm-back">&larr; Poetry</a>

      <!-- Newspaper dateline strip -->
      <div class="tm-dateline">
        <span>An Editorial</span>
        <span>{year}</span>
        <span>Jonathan M. Kelly</span>
      </div>

      <header class="tm-masthead">
        <h1 class="tm-title">
          {titleWords.map((word) => (
            <span class="tm-title-line">
              <span class="tm-overprint tm-overprint-lg" data-text={word}>{word}</span>
            </span>
          ))}
        </h1>
        <p class="tm-deck">An editorial on the collapse.</p>
        <p class="tm-byline">By <span>Jonathan M. Kelly</span></p>
      </header>

      <div class="tm-header-rule" aria-hidden="true"></div>

      <div class="tm-body">
        {stanzas.map((stanza, i) => {
          const cls = stanza.isFinal ? 'tm-stanza tm-final' : 'tm-stanza';
          const isFirst = i === 0;
          return (
            <p class={isFirst ? `${cls} tm-lead` : cls}>
              {stanza.isFinal ? (
                stanza.lines[0].split(' ').map((word, wi, arr) => (
                  <Fragment>
                    <span class="tm-overprint tm-overprint-lg" data-text={word}>{word}</span>
                    {wi < arr.length - 1 && ' '}
                  </Fragment>
                ))
              ) : (
                stanza.lines.map((line, li) => {
                  // Opening stanza, opening line: drop cap + small-caps lead-in.
                  if (isFirst && li === 0 && line.startsWith('They told us')) {
                    const rest = line.slice('They told us'.length);
                    return (
                      <Fragment>
                        <span class="tm-drop" aria-hidden="true">T</span>
                        <span class="tm-smallcaps">hey told us</span>
                        {rest}
                        {li < stanza.lines.length - 1 && <br />}
                      </Fragment>
                    );
                  }
                  const tokens = overprintTokens(line);
                  return (
                    <Fragment>
                      {tokens.map((t) =>
                        t.overprint
                          ? <span class="tm-overprint" data-text={t.text}>{t.text}</span>
                          : <Fragment>{t.text}</Fragment>
                      )}
                      {li < stanza.lines.length - 1 && <br />}
                    </Fragment>
                  );
                })
              )}
            </p>
          );
        })}
        <div class="tm-end-mark" aria-hidden="true">&#9632;</div>
      </div>

      <footer class="tm-footer">
        <a href={`/${next.slug}`} class="tm-next">
          <span class="tm-next-label">Next poem &rarr;</span>
          <span class="tm-next-title">{next.title}</span>
        </a>
      </footer>
    </article>
  </div>

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&display=swap');

    .tm-page {
      --tm-paper: #EDE3CC;
      --tm-paper-deep: #D9CDB2;
      --tm-ink: #0C0A07;
      --tm-muted: rgba(12, 10, 7, 0.55);
      --tm-red: #B32418;
      --tm-typed: 'Courier Prime', 'Courier Prime', monospace;
      background:
        radial-gradient(ellipse 120vw 80vh at 50% 30%,
          #F2E9D2 0%,
          var(--tm-paper) 55%,
          var(--tm-paper-deep) 100%);
      color: var(--tm-ink);
      min-height: 100vh;
      position: relative;
      font-family: var(--tm-typed);
      animation: tm-settle 440ms cubic-bezier(0.2, 0.6, 0.25, 1) both;
    }
    /* Warm yellowing wash — newsprint acid aging */
    .tm-page::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      background:
        radial-gradient(ellipse 140vw 70vh at 8% 0%,
          rgba(200, 150, 60, 0.14) 0%, transparent 60%),
        radial-gradient(ellipse 120vw 80vh at 92% 100%,
          rgba(120, 70, 20, 0.12) 0%, transparent 55%);
      mix-blend-mode: multiply;
    }
    /* Press-settling: the page arrives slightly off-register, settles once. */
    @keyframes tm-settle {
      0%   { transform: translate(2.5px, -1px); }
      55%  { transform: translate(-1.5px, 0.5px); }
      100% { transform: translate(0, 0); }
    }

    /* Paper grain — coarser, warmer, more present. Reads as newsprint fiber. */
    .tm-grain {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      opacity: 0.62;
      mix-blend-mode: multiply;
      z-index: 1;
    }

    /* ── Nav ── */
    .tm-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(245, 242, 234, 0.9);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(15, 12, 10, 0.12);
      padding: 0 var(--page-pad);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .tm-brand {
      font-family: var(--tm-typed);
      font-size: 18px;
      font-weight: 700;
      letter-spacing: 0.04em;
      color: var(--tm-ink);
      text-transform: uppercase;
      text-decoration: none;
    }
    .tm-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .tm-nav-links a {
      font-family: var(--tm-typed);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(15, 12, 10, 0.5);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .tm-nav-links a:hover { color: var(--tm-red); }
    .tm-nav-links a.is-current { color: var(--tm-ink); }

    /* ── Article — tight newsprint column, measure closer to a real
       newspaper text column so lines break at a reading-fatigue-friendly
       width and the page feels printed rather than laid-out. ── */
    .tm-article {
      max-width: 540px;
      margin: 0 auto;
      padding: 112px var(--page-pad) 160px;
      position: relative;
      z-index: 5;
    }

    /* ── Back link (up top, standalone) ── */
    .tm-back {
      display: inline-block;
      font-family: var(--tm-typed);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(15, 12, 10, 0.52);
      text-decoration: none;
      margin-bottom: 36px;
      transition: color 0.2s ease;
    }
    .tm-back:hover { color: var(--tm-red); }

    /* ── Dateline strip (newspaper metadata bar) ── */
    .tm-dateline {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      margin-bottom: 32px;
      border-top: 1px solid var(--tm-ink);
      border-bottom: 1px solid var(--tm-ink);
      font-family: var(--tm-typed);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--tm-ink);
      gap: 18px;
      flex-wrap: wrap;
    }
    .tm-dateline span:nth-child(2) {
      text-align: center;
      flex: 1 1 auto;
    }

    /* ── Masthead ── */
    .tm-masthead {
      margin-bottom: 0;
    }

    /* ── Title — four-line stacked manifesto banner, one word per line.
       Courier Prime 700 uppercase reads as hammered-out typewriter bold. ── */
    .tm-title {
      font-family: var(--tm-typed);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      line-height: 0.92;
      color: var(--tm-ink);
      margin: 0 0 22px;
    }
    .tm-title-line {
      display: block;
      font-size: clamp(52px, 11vw, 112px);
    }

    /* ── Deck (italic typed subtitle) ── */
    .tm-deck {
      font-family: var(--tm-typed);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(15px, 1.8vw, 18px);
      line-height: 1.5;
      color: var(--tm-ink);
      margin: 0 0 18px;
      letter-spacing: 0.01em;
    }

    /* ── Byline ── */
    .tm-byline {
      font-family: var(--tm-typed);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(15, 12, 10, 0.75);
      margin: 0 0 28px;
    }
    .tm-byline span {
      color: var(--tm-ink);
    }

    /* ── Thick masthead/body separator (double rule) ── */
    .tm-header-rule {
      height: 6px;
      border-top: 1px solid var(--tm-ink);
      border-bottom: 3px solid var(--tm-ink);
      margin: 0 0 40px;
    }

    /* ── Body — Courier Prime, tight leading. Monospace is wider per
       character, so font-size is lowered and leading tightened to match
       the density of serif body text. ── */
    .tm-body {
      font-family: var(--tm-typed);
      font-size: 16.5px;
      line-height: 1.6;
      color: var(--tm-ink);
      text-shadow: 0 0 0.5px rgba(12, 10, 7, 0.55);
      letter-spacing: -0.005em;
    }
    .tm-stanza {
      margin: 0 0 26px;
      font-family: var(--tm-typed);
    }
    .tm-stanza:last-of-type { margin-bottom: 0; }
    /* Title gets heavier ink bleed — strong press, lots of ink */
    .tm-title {
      text-shadow:
        0.6px 0 0 rgba(12, 10, 7, 0.35),
        -0.3px 0 0 rgba(12, 10, 7, 0.35),
        0 0 0.8px rgba(12, 10, 7, 0.5);
    }

    /* ── Opening drop cap + small-caps lead-in ── */
    .tm-lead {
      overflow: hidden; /* contain the floated drop cap */
    }
    .tm-drop {
      float: left;
      font-family: var(--tm-typed);
      font-weight: 700;
      font-size: 5.6em;
      line-height: 0.82;
      color: var(--tm-red);
      padding: 6px 12px 0 0;
      margin: 0 4px 0 0;
      text-transform: uppercase;
      text-shadow: 0.5px 0 0 var(--tm-red);
    }
    .tm-smallcaps {
      font-family: var(--tm-typed);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 700;
      font-size: 0.94em;
    }

    /* ── Final line — the verdict, same press run as the banner ── */
    .tm-final {
      margin-top: 80px;
      padding-top: 36px;
      border-top: 3px solid var(--tm-ink);
      font-family: var(--tm-typed);
      font-weight: 700;
      font-size: clamp(26px, 4.6vw, 44px);
      text-transform: uppercase;
      letter-spacing: -0.018em;
      line-height: 1.08;
    }
    .tm-final .tm-overprint {
      font-size: inherit;
      font-weight: inherit;
    }

    /* ── End dingbat ── */
    .tm-end-mark {
      margin: 40px 0 0;
      text-align: center;
      color: var(--tm-red);
      font-size: 14px;
      line-height: 1;
    }

    /* ── Overprint — base treatment ──
       Each span carries data-text equal to its own text. The ::before
       pseudo paints that same text in red, slightly offset and rotated,
       so it reads as a misregistered second pass of red ink. */
    .tm-overprint {
      position: relative;
      display: inline-block;
    }
    .tm-overprint::before {
      content: attr(data-text);
      position: absolute;
      top: 0;
      left: -2px;
      color: var(--tm-red);
      transform: rotate(0.55deg) translate(0, -0.5px);
      opacity: 0.78;
      pointer-events: none;
      z-index: -1;
      /* ensure the pseudo inherits layout */
      font: inherit;
      text-transform: inherit;
      letter-spacing: inherit;
      line-height: inherit;
      white-space: pre;
    }
    /* Larger offset / more visible red for title-scale overprint */
    .tm-overprint-lg::before {
      left: -3px;
      transform: rotate(0.7deg) translate(0, -1px);
      opacity: 0.82;
    }

    /* Final line — overprint with maximum offset for impact */
    .tm-final .tm-overprint-final,
    .tm-final > * .tm-overprint-final {
      /* reserved for future tuning */
    }

    /* ── Footer ── */
    .tm-footer {
      margin-top: 112px;
      padding-top: 40px;
      border-top: 1px solid rgba(15, 12, 10, 0.18);
    }
    .tm-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 10px;
      color: var(--tm-ink);
      transition: color 0.2s ease;
    }
    .tm-next-label {
      font-family: var(--tm-typed);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--tm-red);
    }
    .tm-next-title {
      font-family: var(--tm-typed);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(20px, 2.6vw, 26px);
      line-height: 1.25;
      color: var(--tm-ink);
    }
    .tm-next:hover .tm-next-title { color: var(--tm-red); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .tm-article { padding: 96px var(--page-pad) 120px; }
      .tm-masthead { margin-bottom: 56px; }
      .tm-back { margin-bottom: 36px; }
      .tm-body { font-size: 17.5px; line-height: 1.62; }
      .tm-final { margin-top: 64px; padding-top: 28px; font-size: clamp(22px, 7vw, 32px); }
      .tm-footer { margin-top: 80px; }
      .tm-overprint::before { left: -1.5px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .tm-page { animation: none; }
    }
  </style>
</PoetryLayout>
