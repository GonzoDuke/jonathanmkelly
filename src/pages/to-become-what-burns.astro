---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parseBurns } from '../data/poems/to-become-what-burns.js';

const stanzas = parseBurns();
const year = '2025';
const next = { slug: 'brake-check-this-motherfucker', title: 'Brake Check This' };

// Pre-compute base opacity for each stanza: 0.75 (first) → 1.0 (final).
// The embers layer handles the dynamic atmosphere; stanza brightness
// simply progresses through the poem.
const total = stanzas.length;
const stanzasWithOpacity = stanzas.map((s, i) => ({
  ...s,
  baseOpacity: total === 1 ? 1 : (0.75 + (i / (total - 1)) * 0.25).toFixed(3),
}));
---
<PoetryLayout
  title="To Become What Burns — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/to-become-what-burns"
>
  <div class="tb-page">
    <canvas class="tb-embers" aria-hidden="true"></canvas>
    <div class="tb-embers-fallback" aria-hidden="true">
      <svg viewBox="0 0 60 120" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M30 110 C 12 90, 10 60, 28 40 C 22 58, 30 60, 32 48 C 36 28, 30 16, 30 6
             C 44 22, 50 44, 46 64 C 44 86, 38 102, 30 110 Z"
          fill="#FFA04A"
          opacity="0.55"
        />
      </svg>
    </div>

    <nav class="tb-nav">
      <a href="/" class="tb-brand">JMK</a>
      <div class="tb-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="tb-article">
      <header class="tb-masthead">
        <a href="/poetry" class="tb-back">&larr; Poetry</a>
        <p class="tb-year">{year}</p>
        <h1 class="tb-title">To Become What Burns</h1>
      </header>

      <div class="tb-body">
        {stanzasWithOpacity.map((stanza) => (
          <p
            class={stanza.isFinal ? 'tb-stanza tb-final' : 'tb-stanza'}
            style={`--tb-stanza-opacity: ${stanza.baseOpacity};`}
          >
            {stanza.lines.map((line, i) => {
              const isFireLine = stanza.isFinal && i === 0;
              return (
                <Fragment>
                  {isFireLine ? (
                    <Fragment>
                      <span class="tb-fire-word">Fire</span>
                      {line.slice(4)}
                    </Fragment>
                  ) : (
                    line
                  )}
                  {i < stanza.lines.length - 1 && <br />}
                </Fragment>
              );
            })}
          </p>
        ))}
      </div>

      <footer class="tb-footer">
        <a href={`/${next.slug}`} class="tb-next">
          <span class="tb-next-label">Next poem &rarr;</span>
          <span class="tb-next-title">{next.title}</span>
        </a>
      </footer>
    </article>
  </div>

  <style is:global>
    .tb-page {
      --tb-bg: #000000;
      --tb-text: #F4EBD4;
      --tb-muted: rgba(244, 235, 212, 0.55);
      --tb-amber: #FFA04A;
      --tb-amber-bright: #FFC078;
      background: var(--tb-bg);
      color: var(--tb-text);
      min-height: 100vh;
      position: relative;
      font-family: var(--serif);
      overflow-x: hidden;
    }

    /* Canvas ember layer sits fixed behind everything */
    .tb-embers {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      display: block;
    }
    .tb-embers-fallback {
      display: none;
      position: fixed;
      left: 50%;
      bottom: 12vh;
      width: 60px;
      height: 120px;
      transform: translateX(-50%);
      pointer-events: none;
      z-index: 0;
    }

    /* ── Nav ── */
    .tb-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(244, 235, 212, 0.06);
      padding: 0 var(--page-pad);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .tb-brand {
      font-family: var(--serif);
      font-size: 20px;
      font-weight: 500;
      font-style: italic;
      color: var(--tb-text);
      text-decoration: none;
      letter-spacing: -0.01em;
    }
    .tb-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .tb-nav-links a {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(244, 235, 212, 0.38);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .tb-nav-links a:hover { color: var(--tb-amber); }
    .tb-nav-links a.is-current { color: rgba(244, 235, 212, 0.82); }

    /* ── Article ── */
    .tb-article {
      max-width: 620px;
      margin: 0 auto;
      padding: 144px var(--page-pad) 160px;
      position: relative;
      z-index: 5;
    }

    /* ── Masthead ── */
    .tb-masthead { margin-bottom: 96px; }
    .tb-back {
      display: inline-block;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(244, 235, 212, 0.42);
      text-decoration: none;
      margin-bottom: 64px;
      transition: color 0.3s ease;
    }
    .tb-back:hover { color: var(--tb-amber); }
    .tb-year {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 160, 74, 0.6);
      margin: 0 0 26px;
    }
    .tb-title {
      font-family: var(--serif);
      font-size: clamp(52px, 8.5vw, 88px);
      font-weight: 400;
      letter-spacing: -0.015em;
      line-height: 1.02;
      color: var(--tb-text);
      margin: 0;
    }

    /* ── Body ── */
    .tb-body {
      font-family: var(--serif);
      font-size: clamp(21px, 2.2vw, 23px);
      line-height: 1.82;
      color: var(--tb-text);
      letter-spacing: 0.01em;
    }
    .tb-stanza {
      margin: 0 0 44px;
      opacity: var(--tb-stanza-opacity, 1);
      font-weight: 400;
    }
    .tb-stanza:last-child { margin-bottom: 0; }
    .tb-final {
      font-style: italic;
      margin-top: 56px;
      font-weight: 400;
    }
    .tb-fire-word {
      color: var(--tb-amber-bright);
      font-style: italic;
    }

    /* ── Footer / Next poem ── */
    .tb-footer {
      margin-top: 144px;
      padding-top: 44px;
      border-top: 1px solid rgba(244, 235, 212, 0.14);
    }
    .tb-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 10px;
      color: var(--tb-text);
      transition: color 0.3s ease;
    }
    .tb-next-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255, 160, 74, 0.65);
    }
    .tb-next-title {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 500;
      font-size: clamp(22px, 3vw, 28px);
      line-height: 1.2;
      color: var(--tb-text);
    }
    .tb-next:hover .tb-next-title { color: var(--tb-amber); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .tb-article { padding: 108px var(--page-pad) 120px; }
      .tb-masthead { margin-bottom: 72px; }
      .tb-back { margin-bottom: 48px; }
      .tb-body { font-size: 19.5px; line-height: 1.78; }
      .tb-stanza { margin-bottom: 36px; }
      .tb-footer { margin-top: 96px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .tb-embers { display: none; }
      .tb-embers-fallback { display: block; }
    }
  </style>

  <script>
    // Drifting-embers canvas — see brief: 8–15 embers, randomized x /
    // velocity / fade. Count scales with scroll progress (start at 4,
    // reach ~13 at final stanza). requestAnimationFrame loop, paused on
    // tab-blur.
    const canvas = document.querySelector<HTMLCanvasElement>('.tb-embers');
    if (canvas && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        let dpr = Math.min(window.devicePixelRatio || 1, 2);
        let W = 0, H = 0;

        type Ember = {
          x: number;
          y: number;
          vy: number;
          drift: number;
          driftPhase: number;
          r: number;
          life: number;
          maxLife: number;
        };
        const embers: Ember[] = [];
        const isMobile = window.matchMedia('(max-width: 640px)').matches;
        const minCount = isMobile ? 5 : 7;
        const maxCount = isMobile ? 13 : 20;

        // Cave-wall firelight: 3 slow warmth pools that drift and pulse
        // independently. Drawn behind embers. Each is a large soft radial
        // gradient whose center oscillates on two different sine axes so
        // the pattern never obviously repeats.
        type Warmth = {
          cx: number; cy: number;           // base center (ratio of viewport)
          xAmp: number; yAmp: number;       // drift amplitude (ratio)
          xFreq: number; yFreq: number;     // rad/ms
          xPhase: number; yPhase: number;
          radius: number;                    // ratio of min(W, H)
          intensity: number;                 // base alpha
          pulseAmp: number; pulseFreq: number; pulsePhase: number;
          r: number; g: number; b: number;
        };
        const warmths: Warmth[] = [
          { cx: 0.22, cy: 0.82, xAmp: 0.14, yAmp: 0.06,
            xFreq: 0.00013, yFreq: 0.00019, xPhase: 0.0, yPhase: 1.3,
            radius: 0.58, intensity: 0.11, pulseAmp: 0.05,
            pulseFreq: 0.00042, pulsePhase: 0.0,
            r: 255, g: 128, b: 50 },
          { cx: 0.78, cy: 0.88, xAmp: 0.16, yAmp: 0.07,
            xFreq: 0.00011, yFreq: 0.00023, xPhase: 2.7, yPhase: 0.5,
            radius: 0.64, intensity: 0.10, pulseAmp: 0.055,
            pulseFreq: 0.00037, pulsePhase: 1.8,
            r: 255, g: 100, b: 36 },
          { cx: 0.50, cy: 0.42, xAmp: 0.22, yAmp: 0.12,
            xFreq: 0.00009, yFreq: 0.00015, xPhase: 4.1, yPhase: 3.2,
            radius: 0.52, intensity: 0.07, pulseAmp: 0.04,
            pulseFreq: 0.00051, pulsePhase: 2.5,
            r: 255, g: 170, b: 95 },
        ];

        const resize = () => {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          W = canvas.clientWidth;
          H = canvas.clientHeight;
          canvas.width = W * dpr;
          canvas.height = H * dpr;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };
        resize();
        window.addEventListener('resize', resize);

        const spawn = (): Ember => {
          const maxLife = 6800 + Math.random() * 4400;
          return {
            x: Math.random() * W,
            y: H + Math.random() * 40,
            vy: 0.3 + Math.random() * 0.55,
            drift: 0.2 + Math.random() * 0.45,
            driftPhase: Math.random() * Math.PI * 2,
            r: 1.1 + Math.random() * 1.9,
            life: 0,
            maxLife,
          };
        };

        const scrollRatio = () => {
          const doc = document.documentElement;
          const denom = (doc.scrollHeight - window.innerHeight) || 1;
          return Math.min(1, Math.max(0, window.scrollY / denom));
        };
        const target = () => {
          const r = scrollRatio();
          return Math.round(minCount + (maxCount - minCount) * r);
        };

        let last = performance.now();
        let running = true;
        let rafId: number | null = null;

        const draw = (now: number) => {
          rafId = null;
          if (!running) return;
          const dt = Math.min(64, now - last);
          last = now;

          ctx.clearRect(0, 0, W, H);

          // ── firelight warmth on cave walls ──
          // Large soft radial gradients, slow drift, slow pulse.
          // Use lighter composite so overlapping pools additively glow
          // without fighting the black background.
          const prevOp = ctx.globalCompositeOperation;
          ctx.globalCompositeOperation = 'lighter';
          const minDim = Math.min(W, H);
          for (const w of warmths) {
            const cx = (w.cx + Math.sin(now * w.xFreq + w.xPhase) * w.xAmp) * W;
            const cy = (w.cy + Math.sin(now * w.yFreq + w.yPhase) * w.yAmp) * H;
            const rad = w.radius * minDim;
            const pulse = Math.sin(now * w.pulseFreq + w.pulsePhase);
            const alpha = Math.max(0, w.intensity + pulse * w.pulseAmp);
            const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, rad);
            grad.addColorStop(0,    `rgba(${w.r}, ${w.g}, ${w.b}, ${alpha})`);
            grad.addColorStop(0.45, `rgba(${w.r}, ${w.g}, ${w.b}, ${alpha * 0.35})`);
            grad.addColorStop(1,    `rgba(${w.r}, ${w.g}, ${w.b}, 0)`);
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, W, H);
          }
          ctx.globalCompositeOperation = prevOp;

          // ── embers ──
          for (let i = embers.length - 1; i >= 0; i--) {
            const e = embers[i];
            e.life += dt;
            e.y -= e.vy * (dt / 16);
            e.x += Math.sin((e.life / 900) + e.driftPhase) * (e.drift * dt / 60);

            const lifeRatio = e.life / e.maxLife;
            // fade in over first 14%, hold at full brightness through 74%,
            // fade out over final 26% — longer life in the upper half so
            // they reach higher before dissipating.
            let alpha;
            if (lifeRatio < 0.14) alpha = lifeRatio / 0.14;
            else if (lifeRatio > 0.74) alpha = Math.max(0, 1 - (lifeRatio - 0.74) / 0.26);
            else alpha = 1;

            if (lifeRatio >= 1 || e.y < -20) {
              embers.splice(i, 1);
              continue;
            }

            const a = alpha * 0.78;
            const grad = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r * 4);
            grad.addColorStop(0, `rgba(255, 190, 120, ${a})`);
            grad.addColorStop(0.35, `rgba(255, 160, 74, ${a * 0.6})`);
            grad.addColorStop(1, 'rgba(255, 120, 40, 0)');
            ctx.fillStyle = grad;
            ctx.beginPath();
            ctx.arc(e.x, e.y, e.r * 4, 0, Math.PI * 2);
            ctx.fill();

            // bright core
            ctx.fillStyle = `rgba(255, 220, 170, ${alpha * 0.9})`;
            ctx.beginPath();
            ctx.arc(e.x, e.y, e.r, 0, Math.PI * 2);
            ctx.fill();
          }

          // top up to target
          const t = target();
          while (embers.length < t) embers.push(spawn());

          rafId = requestAnimationFrame(draw);
        };
        rafId = requestAnimationFrame(draw);

        const pause = () => {
          running = false;
          if (rafId !== null) cancelAnimationFrame(rafId);
          rafId = null;
        };
        const resume = () => {
          if (running) return;
          running = true;
          last = performance.now();
          rafId = requestAnimationFrame(draw);
        };
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') pause();
          else resume();
        });
        document.addEventListener('astro:before-swap', pause);
      }
    }
  </script>
</PoetryLayout>
