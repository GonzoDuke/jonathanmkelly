---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import ToBecomeWhatBurns from '../components/pieces/poems/ToBecomeWhatBurns.jsx';

const piece = PIECES.find(p => p.id === 'to-become-what-burns');
---

<PieceLayout piece={piece}>
  <ToBecomeWhatBurns client:load />
</PieceLayout>
