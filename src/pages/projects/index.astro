---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Hybrid Projects — Jonathan M. Kelly" description="Larger works that live on their own, under their own names." ogUrl="https://www.jonathanmkelly.com/projects">
  <div style="background: #1e3228; min-height: 100vh; position: relative; overflow: hidden;">
    <!-- Organic texture -->
    <div style={`
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse at 25% 40%, rgba(40,70,50,0.2) 0%, transparent 60%),
        radial-gradient(ellipse at 75% 70%, rgba(30,55,38,0.15) 0%, transparent 50%);
      pointer-events: none;
    `}></div>

    <!-- Nav -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(30,50,40,0.92);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(76,112,72,0.12);
      padding: 0 var(--page-pad);
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    `}>
      <a href="/" style={`
        font-family: var(--serif); font-size: 20px; font-weight: 500;
        color: #d4b896; text-decoration: none; letter-spacing: -0.01em;
      `}>JMK</a>
      <div style="display: flex; gap: clamp(20px, 3vw, 36px); align-items: center; flex-wrap: wrap;">
        <a href="/projects" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(212,184,150,0.8); text-decoration: none;">Projects</a>
        <a href="/detourist" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(212,184,150,0.4); text-decoration: none;">detourist</a>
        <a href="/poetry" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(212,184,150,0.4); text-decoration: none;">Poetry</a>
        <a href="/agency-artifact" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(212,184,150,0.4); text-decoration: none;">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(212,184,150,0.4); text-decoration: none;">Contact</a>
        <a href="/about" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(212,184,150,0.4); text-decoration: none;">About</a>
        <button
          class="share-btn"
          data-title="Hybrid Projects — Jonathan M. Kelly"
          data-text="Larger works that live on their own, under their own names. By Jonathan M. Kelly"
          data-url="https://www.jonathanmkelly.com/projects"
          style={`
            background: none; border: 1px solid rgba(76,112,72,0.2);
            border-radius: 3px; padding: 5px 12px; cursor: pointer;
            font-family: var(--mono); font-size: 10px; font-weight: 400;
            letter-spacing: 0.06em; text-transform: uppercase;
            color: rgba(212,184,150,0.35); transition: all 0.2s ease;
          `}>Share</button>
      </div>
    </nav>

    <!-- Header -->
    <header style="max-width: 1200px; margin: 0 auto; padding: 112px var(--page-pad) 0; position: relative; z-index: 1;">
      <h1 style={`
        font-family: 'Alegreya SC', var(--serif); font-size: clamp(48px, 8vw, 80px);
        font-weight: 400; line-height: 0.95;
        color: #d4b896; letter-spacing: 0.01em;
        margin: 0 0 24px;
      `}>Hybrid Projects</h1>
      <p style={`
        font-family: var(--body); font-size: 18px;
        color: rgba(212,184,150,0.5); line-height: 1.7;
        max-width: 600px; margin: 0 0 56px;
      `}>These are larger, self-contained works. Each lives on its own domain, under its own name, with its own curatorial voice. They grew out of the same questions that drive everything else here, but they needed their own space to answer them.</p>
      <div style="height: 2px; background: rgba(76,112,72,0.3); width: 60px;"></div>
    </header>

    <!-- Project cards -->
    <main style="max-width: 1200px; margin: 0 auto; padding: 56px var(--page-pad) 0; position: relative; z-index: 1;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 480px), 1fr)); gap: 32px;">

        <!-- ═══ THE B-SIDE OF EVERYTHING ═══ -->
        <a href="https://thebsideofeverything.com" target="_blank" rel="noopener noreferrer" style={`
          display: block; text-decoration: none;
          background: #1a1714;
          padding: 0;
          transition: all 0.3s ease;
          position: relative; overflow: hidden;
        `}
        onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 20px 60px rgba(0,0,0,0.4)'"
        onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='none'"
        >
          <div style={`
            position: absolute; inset: 0;
            background:
              radial-gradient(ellipse at 30% 30%, rgba(90,70,40,0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 70%, rgba(70,50,25,0.12) 0%, transparent 50%),
              linear-gradient(160deg, rgba(50,40,28,0.3) 0%, rgba(26,23,20,0) 40%);
            pointer-events: none;
          `}></div>

          <div style={`
            padding: clamp(36px, 5vw, 52px);
            position: relative; z-index: 1;
          `}>
            <div style={`
              display: flex; align-items: center; gap: 12px;
              margin-bottom: 24px;
            `}>
              <div style={`
                width: 28px; height: 28px; border-radius: 50%;
                border: 2px solid rgba(240,236,228,0.1);
                position: relative;
              `}>
                <div style={`
                  width: 6px; height: 6px; border-radius: 50%;
                  background: rgba(240,236,228,0.15);
                  position: absolute; top: 50%; left: 50%;
                  transform: translate(-50%, -50%);
                `}></div>
              </div>
              <span style={`
                font-family: var(--mono); font-size: 9px; font-weight: 400;
                letter-spacing: 0.12em; text-transform: uppercase;
                color: rgba(240,236,228,0.25);
              `}>thebsideofeverything.com</span>
            </div>

            <div style={`
              font-family: var(--serif); font-size: clamp(28px, 3.5vw, 40px);
              font-weight: 400; line-height: 1.12;
              color: #f0ece4; letter-spacing: -0.01em; margin-bottom: 16px;
            `}>The B-Side of Everything</div>
            <p style={`
              font-family: var(--body); font-size: 15px;
              font-style: italic; line-height: 1.65;
              color: rgba(240,236,228,0.5); margin: 0 0 16px;
            `}>Writing about music that didn't survive its own context. Bands without archives. Scenes without historians.</p>
            <p style={`
              font-family: var(--body); font-size: 14px; line-height: 1.65;
              color: rgba(240,236,228,0.35); margin: 0;
            `}>Liner notes, live reviews, dissertations, radio transcripts, zine pages, and record guide entries. Music journalism spanning five decades.</p>

            <div style={`
              margin-top: 28px; padding-top: 16px;
              border-top: 1px solid rgba(240,236,228,0.06);
              display: flex; justify-content: space-between; align-items: center;
            `}>
              <span style={`
                font-family: var(--mono); font-size: 10px; font-weight: 300;
                font-style: italic; color: rgba(240,236,228,0.2);
              `}>Collected by TL Skinsbury</span>
              <span style={`
                font-family: var(--mono); font-size: 12px;
                color: rgba(240,236,228,0.25);
              `}>&rarr;</span>
            </div>
          </div>
        </a>

        <!-- ═══ THE COLLECTED WORKS OF ROWAN BLACK ═══ -->
        <a href="https://whoisrowanblack.com" target="_blank" rel="noopener noreferrer" style={`
          display: block; text-decoration: none;
          background: #eef0f4;
          border: none;
          border-radius: 8px;
          overflow: hidden;
          transition: all 0.3s ease;
          box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        `}
        onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 20px 60px rgba(0,0,0,0.15)'"
        onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.08)'"
        >
          <div style={`
            background: linear-gradient(180deg, #e8eaee 0%, #d8dae0 100%);
            border-bottom: 1px solid #c8cad0;
            padding: 10px 16px;
            display: flex; align-items: center; gap: 8px;
          `}>
            <div style="display: flex; gap: 6px;">
              <div style="width: 12px; height: 12px; border-radius: 50%; background: #ff5f57;"></div>
              <div style="width: 12px; height: 12px; border-radius: 50%; background: #ffbd2e;"></div>
              <div style="width: 12px; height: 12px; border-radius: 50%; background: #28c840;"></div>
            </div>
            <span style={`
              font-family: var(--mono); font-size: 11px; font-weight: 400;
              color: #6a7088; margin-left: 8px;
            `}>corvids@archive: ~/collected-works/rowan-black</span>
          </div>

          <div style={`
            background: #ffffff;
            margin: 16px;
            border-radius: 2px;
            padding: clamp(28px, 4vw, 40px);
          `}>
            <div style={`
              font-family: var(--serif); font-size: clamp(24px, 3vw, 32px);
              font-weight: 400; line-height: 1.15;
              color: #1a1d24; margin-bottom: 4px;
            `}>The Collected Works of <span style="font-weight: 700;">Rowan Black</span></div>
            <div style={`
              font-family: var(--mono); font-size: 13px; line-height: 1.75;
              color: #5a6070; margin: 16px 0 20px;
            `}>Recovered archive. Poems, essays, fragments, and digital artifacts assembled by the Corvids Collective. Some files are damaged. Some are incomplete. All are preserved as found.</div>
            <div style={`
              display: flex; gap: 16px; flex-wrap: wrap;
            `}>
              <span style={`
                font-family: var(--mono); font-size: 12px;
                color: #2a6dd4;
              `}>Who is Rowan Black</span>
              <span style={`
                font-family: var(--mono); font-size: 12px;
                color: #2a6dd4;
              `}>A Letter from the Corvids Collective</span>
            </div>

            <div style={`
              margin-top: 24px; padding-top: 14px;
              border-top: 1px solid rgba(0,0,0,0.06);
              display: flex; justify-content: space-between; align-items: center;
            `}>
              <span style={`
                font-family: var(--mono); font-size: 11px;
                color: #9099a8;
              `}>whoisrowanblack.com</span>
              <span style={`
                font-family: var(--mono); font-size: 12px;
                color: #9099a8;
              `}>&rarr;</span>
            </div>
          </div>
        </a>

      </div>
    </main>

    <!-- Footer -->
    <footer style="max-width: 1200px; margin: 0 auto; padding: 80px var(--page-pad) 120px; text-align: center; position: relative; z-index: 1;">
      <div style="height: 2px; background: rgba(76,112,72,0.12); width: 60px; margin: 0 auto 32px;"></div>
      <a href="/" style={`
        font-family: var(--mono); font-size: 13px; font-weight: 400;
        letter-spacing: 0.04em; color: rgba(212,184,150,0.35);
        text-decoration: none;
      `}>&larr; Back</a>
    </footer>
  </div>
  <script>
    document.querySelectorAll('.share-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const data = { title: btn.dataset.title, text: btn.dataset.text, url: btn.dataset.url };
        if (navigator.share) {
          try { await navigator.share(data); } catch {}
        } else {
          await navigator.clipboard.writeText(data.url);
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = 'Share'; }, 1500);
        }
      });
    });
  </script>
</BaseLayout>
