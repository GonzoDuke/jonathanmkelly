---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parseBriefcase } from '../data/poems/briefcase-full-of-rainbows.js';

const stanzas = parseBriefcase();
const year = '2023';
const next = { slug: 'sleepwrong', title: 'sleepwrong' };
---
<PoetryLayout
  title="Briefcase Full of Rainbows — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/briefcase-full-of-rainbows"
>
  <div class="bf-page">
    <div class="bf-ribbon bf-ribbon-left" aria-hidden="true"></div>
    <div class="bf-ribbon bf-ribbon-right" aria-hidden="true"></div>
    <div class="bf-aurora" aria-hidden="true"></div>

    <nav class="bf-nav">
      <a href="/" class="bf-brand">JMK</a>
      <div class="bf-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="bf-article">
      <header class="bf-masthead">
        <a href="/poetry" class="bf-back">&larr; Poetry</a>
        <p class="bf-year">{year}</p>
        <h1 class="bf-title">Briefcase Full of <span class="bf-title-prism">Rainbows</span></h1>
      </header>

      <div class="bf-body">
        {stanzas.map((stanza) => {
          const cls = stanza.role
            ? `bf-stanza bf-${stanza.role}`
            : 'bf-stanza';
          return (
            <p class={cls}>
              {stanza.lines.map((line, i) => {
                const isMikeLine = stanza.hasMike && line === stanza.mikeLine;
                return (
                  <Fragment>
                    {isMikeLine
                      ? <span class="bf-mike" data-trigger="mike">{line}</span>
                      : line}
                    {i < stanza.lines.length - 1 && <br />}
                  </Fragment>
                );
              })}
            </p>
          );
        })}
      </div>

      <footer class="bf-footer">
        <a href={`/${next.slug}`} class="bf-next">
          <span class="bf-next-label">Next poem &rarr;</span>
          <span class="bf-next-title">{next.title}</span>
        </a>
      </footer>
    </article>
  </div>

  <style is:global>
    .bf-page {
      --bf-ink: #1A1714;
      --bf-gray-cool: #C4C0B8;
      --bf-gray-warm: #E4DAC6;
      --bf-brown-gold: #8B6A2A;
      --bf-amber: #D4A574;
      --bf-warm: 0%;
      background: color-mix(in srgb, var(--bf-gray-cool), var(--bf-gray-warm) var(--bf-warm));
      color: var(--bf-ink);
      min-height: 100vh;
      position: relative;
      font-family: var(--poetry-humanist);
      transition: background 0.8s ease;
    }

    /* ── Oil-slick ribbons (both edges) ── */
    .bf-ribbon {
      position: fixed;
      top: 0;
      bottom: 0;
      width: 18px;
      z-index: 100;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        #6b2a8a 0%,
        #2460b0 14%,
        #28a0a0 28%,
        #3da858 42%,
        #d48a20 56%,
        #e05050 70%,
        #e070b0 84%,
        #6b2a8a 100%
      );
      background-size: 100% 200vh;
      background-repeat: repeat-y;
      animation: bf-ribbon-drift 18s linear infinite;
      filter: saturate(1.05);
      transition: width 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                  filter 0.7s ease,
                  box-shadow 0.7s ease;
    }
    .bf-ribbon-left {
      left: 0;
      box-shadow: 2px 0 24px rgba(0, 0, 0, 0.1),
                  6px 0 40px rgba(107, 42, 138, 0.12);
    }
    .bf-ribbon-right {
      right: 0;
      animation-delay: -9s;
      animation-direction: reverse;
      box-shadow: -2px 0 24px rgba(0, 0, 0, 0.1),
                  -6px 0 40px rgba(61, 168, 88, 0.12);
    }
    @keyframes bf-ribbon-drift {
      from { background-position-y: 0; }
      to   { background-position-y: -200vh; }
    }
    .bf-page.is-mike .bf-ribbon {
      width: 36px;
      filter: saturate(1.4) brightness(1.15);
    }
    .bf-page.is-mike .bf-ribbon-left {
      box-shadow: 4px 0 40px rgba(212, 165, 116, 0.5),
                  12px 0 80px rgba(107, 42, 138, 0.35);
    }
    .bf-page.is-mike .bf-ribbon-right {
      box-shadow: -4px 0 40px rgba(212, 165, 116, 0.5),
                  -12px 0 80px rgba(61, 168, 88, 0.35);
    }

    /* ── Aurora: page-wide prismatic wash, idle at 0, blooms on Mike ── */
    .bf-aurora {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      background:
        radial-gradient(ellipse 70vw 40vh at 15% 20%,
          rgba(107, 42, 138, 0.22) 0%, transparent 60%),
        radial-gradient(ellipse 70vw 50vh at 85% 70%,
          rgba(224, 112, 176, 0.2) 0%, transparent 62%),
        radial-gradient(ellipse 50vw 30vh at 50% 90%,
          rgba(212, 138, 32, 0.18) 0%, transparent 60%);
      mix-blend-mode: screen;
      transition: opacity 1.2s ease;
    }
    .bf-page.is-mike .bf-aurora {
      opacity: 1;
    }

    /* ── Nav ── */
    .bf-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(196, 192, 184, 0.88);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(26, 23, 20, 0.1);
      padding: 0 calc(var(--page-pad) + 24px);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .bf-brand {
      font-family: var(--poetry-slab);
      font-size: 20px;
      font-weight: 700;
      color: var(--bf-ink);
      text-decoration: none;
      letter-spacing: -0.005em;
    }
    .bf-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .bf-nav-links a {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(26, 23, 20, 0.45);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .bf-nav-links a:hover { color: var(--bf-brown-gold); }
    .bf-nav-links a.is-current { color: rgba(26, 23, 20, 0.85); }

    /* ── Article ── */
    .bf-article {
      max-width: 640px;
      margin: 0 auto;
      padding: 120px calc(var(--page-pad) + 24px) 160px calc(var(--page-pad) + 24px);
      position: relative;
      z-index: 5;
    }

    /* ── Masthead ── */
    .bf-masthead { margin-bottom: 80px; }
    .bf-back {
      display: inline-block;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(26, 23, 20, 0.48);
      text-decoration: none;
      margin-bottom: 56px;
      transition: color 0.3s ease;
    }
    .bf-back:hover { color: var(--bf-brown-gold); }
    .bf-year {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(26, 23, 20, 0.55);
      margin: 0 0 22px;
    }
    .bf-title {
      font-family: var(--poetry-slab);
      font-size: clamp(48px, 7.8vw, 78px);
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.0;
      color: var(--bf-ink);
      margin: 0;
    }
    .bf-title-prism {
      background: linear-gradient(
        92deg,
        #6b2a8a 0%,
        #2460b0 18%,
        #28a0a0 34%,
        #3da858 50%,
        #d48a20 66%,
        #e05050 82%,
        #e070b0 100%
      );
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      animation: bf-title-shimmer 12s linear infinite;
    }
    @keyframes bf-title-shimmer {
      from { background-position-x: 0%; }
      to   { background-position-x: 200%; }
    }

    /* ── Body ── */
    .bf-body {
      font-family: var(--poetry-humanist);
      font-size: 19.5px;
      line-height: 1.72;
      color: var(--bf-ink);
    }
    .bf-stanza {
      margin: 0 0 30px;
    }
    .bf-stanza:last-child { margin-bottom: 0; }

    /* Mantra recurrences — progressively warmer */
    .bf-mantra-first {
      color: var(--bf-ink);
      font-family: var(--poetry-slab);
      font-weight: 400;
      font-size: 20px;
      line-height: 1.5;
      padding: 20px 0;
      margin: 12px 0 30px;
      border-top: 1px solid rgba(26, 23, 20, 0.18);
      border-bottom: 1px solid rgba(26, 23, 20, 0.18);
    }
    .bf-mantra-last {
      font-family: var(--poetry-slab);
      font-style: italic;
      font-size: clamp(26px, 3.4vw, 34px);
      line-height: 1.3;
      font-weight: 600;
      margin: 72px 0 48px;
      letter-spacing: -0.01em;
      background: linear-gradient(
        94deg,
        #6b2a8a 0%,
        #2460b0 18%,
        #28a0a0 34%,
        #3da858 50%,
        #d48a20 66%,
        #e05050 82%,
        #e070b0 100%
      );
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
      animation: bf-title-shimmer 14s linear infinite;
    }

    /* Mike line — tracked by IntersectionObserver */
    .bf-mike {
      display: inline;
    }

    /* ── Footer ── */
    .bf-footer {
      margin-top: 100px;
      padding-top: 36px;
      border-top: 1px solid rgba(26, 23, 20, 0.16);
    }
    .bf-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 10px;
      color: var(--bf-ink);
      transition: color 0.3s ease;
    }
    .bf-next-label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--bf-brown-gold);
    }
    .bf-next-title {
      font-family: var(--poetry-classical);
      font-style: italic;
      font-weight: 500;
      font-size: clamp(22px, 3vw, 28px);
      line-height: 1.2;
      color: var(--bf-ink);
    }
    .bf-next:hover .bf-next-title { color: var(--bf-brown-gold); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .bf-ribbon { width: 12px; }
      .bf-article {
        padding: 96px calc(var(--page-pad) + 18px) 120px calc(var(--page-pad) + 18px);
      }
      .bf-nav { padding: 0 calc(var(--page-pad) + 16px); }
      .bf-masthead { margin-bottom: 64px; }
      .bf-back { margin-bottom: 40px; }
      .bf-body { font-size: 17.5px; line-height: 1.7; }
      .bf-mantra-first { font-size: 18px; }
      .bf-mantra-last { font-size: 22px; margin: 56px 0 40px; }
      .bf-footer { margin-top: 72px; }
      .bf-page.is-mike .bf-ribbon { width: 22px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .bf-ribbon { animation: none; }
      .bf-title-prism, .bf-mantra-last { animation: none; }
      .bf-page { transition: none; }
      .bf-page.is-mike .bf-ribbon { width: 22px; }
      .bf-aurora { transition: none; }
    }
  </style>

  <script>
    const page = document.querySelector<HTMLElement>('.bf-page');

    // ── Background warming tied to scroll ─────────────────────────
    if (page) {
      let ticking = false;
      const update = () => {
        const doc = document.documentElement;
        const denom = (doc.scrollHeight - window.innerHeight) || 1;
        const ratio = Math.min(1, Math.max(0, window.scrollY / denom));
        page.style.setProperty('--bf-warm', `${(ratio * 100).toFixed(1)}%`);
        ticking = false;
      };
      const onScroll = () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', update);
      update();
    }

    // ── Mike trigger: ribbon widens/brightens for ~2s ─────────────
    const mike = document.querySelector<HTMLElement>('[data-trigger="mike"]');
    if (page && mike && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          page.classList.add('is-mike');
          window.setTimeout(() => page.classList.remove('is-mike'), 2200);
          io.unobserve(entry.target);
        });
      }, { threshold: 0.7 });
      io.observe(mike);
    }
  </script>
</PoetryLayout>
