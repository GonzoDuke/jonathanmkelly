---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Jonathan M. Kelly" description="Poet, essayist, fiction-maker." ogUrl="https://jonathanmkelly.com/about">
  <div style="background: var(--bg); min-height: 100vh;">
    <!-- Nav -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(250,248,245,0.92);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--rule);
      padding: 0 var(--page-pad);
      display: flex; align-items: center; height: 48px;
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 11px; font-weight: 400;
        letter-spacing: 0.04em; color: var(--ghost); text-decoration: none;
      `}>&larr; Jonathan M. Kelly</a>
    </nav>

    <!-- Content -->
    <main style="max-width: 900px; margin: 0 auto; padding: 88px var(--page-pad) 120px;">
      <h1 style={`
        font-family: var(--serif);
        font-size: clamp(40px, 6vw, 60px);
        font-weight: 400; line-height: 1.05;
        color: var(--text); letter-spacing: -0.025em;
        margin: 0 0 32px;
      `}>About</h1>
      <div style="height: 1px; background: var(--rule); margin-bottom: 40px;"></div>

      <div style="font-family: var(--body); font-size: 19px; line-height: 1.7; color: var(--text); max-width: 720px;">
        <p style="margin: 0 0 24px;">
          Jonathan M. Kelly is a poet, essayist, and fiction-maker. He holds a D.Litt. in Creative Writing from Drew University, where his dissertation "The Glitch Is the Machine" was passed with distinction.
        </p>
        <p style="margin: 0 0 24px;">
          His work moves between poetry, critical essays on craft, and digital fiction projects that test the boundaries between what is real and what is constructed. He is the creator of
          <a href="https://thebsideofeverything.com" target="_blank" rel="noopener noreferrer">The B-Side of Everything</a>, a collection of para-fictional music writing, and
          <a href="https://whoisrowanblack.com" target="_blank" rel="noopener noreferrer">The Collected Works of Rowan Black</a>, a recovered archive of poems and fragments by a fictional composite author.
        </p>
        <p style="margin: 0;">
          Contact: <a href="mailto:contact@jonathanmkelly.com">contact@jonathanmkelly.com</a>
        </p>
      </div>
    </main>
  </div>
</BaseLayout>
