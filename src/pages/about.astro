---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Jonathan M. Kelly" description="Poet and writer." ogUrl="https://jonathanmkelly.com/about">
  <div style="background: #1a1a20; min-height: 100vh;">
    <!-- Nav -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(26,26,32,0.92);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(240,236,228,0.06);
      padding: 0 var(--page-pad);
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    `}>
      <a href="/" style={`
        font-family: var(--serif); font-size: 20px; font-weight: 500;
        color: #f0ece4; text-decoration: none; letter-spacing: -0.01em;
      `}>JMK</a>
      <div style="display: flex; gap: clamp(20px, 3vw, 36px); align-items: center;">
        <a href="/detourist" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(240,236,228,0.5); text-decoration: none;">detourist</a>
        <a href="/poetry" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(240,236,228,0.5); text-decoration: none;">Poetry</a>
        <a href="/agency-artifact" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(240,236,228,0.5); text-decoration: none;">A&amp;A</a>
        <a href="/projects" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(240,236,228,0.5); text-decoration: none;">Projects</a>
        <a href="mailto:contact@jonathanmkelly.com" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(240,236,228,0.5); text-decoration: none;">Contact</a>
        <a href="/about" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(240,236,228,0.8); text-decoration: none;">About</a>
      </div>
    </nav>

    <main style="max-width: 1200px; margin: 0 auto; padding: 140px var(--page-pad) 120px;">
      <!-- Two-column layout: title left, content right -->
      <div style={`
        display: flex; gap: clamp(48px, 6vw, 120px);
        align-items: flex-start; flex-wrap: wrap;
      `}>
        <!-- Left column -->
        <div style="flex: 0 0 auto; min-width: 280px;">
          <h1 style={`
            font-family: var(--serif);
            font-size: clamp(48px, 7vw, 72px);
            font-weight: 400; line-height: 0.95;
            color: #f0ece4; letter-spacing: -0.03em;
            margin: 0 0 20px;
          `}>About</h1>
          <div style="height: 1px; background: rgba(240,236,228,0.1); width: 48px; margin-bottom: 24px;"></div>
          <p style={`
            font-family: var(--serif); font-size: 20px;
            font-weight: 300; font-style: italic;
            color: rgba(240,236,228,0.3); line-height: 1.4;
          `}>Poet &middot; Writer</p>
        </div>

        <!-- Right column -->
        <div style="flex: 1 1 400px; max-width: 600px;">
          <div style="font-family: var(--body); font-size: 18px; line-height: 1.8; color: rgba(240,236,228,0.7);">
            <p style="margin: 0 0 24px;">
              Jonathan M. Kelly is a poet and writer. He holds a D.Litt. in Creative Writing from Drew University, where his dissertation "The Glitch Is the Machine" was passed with distinction.
            </p>
            <p style="margin: 0 0 24px;">
              By day, he works as a school librarian at a prep school in northern New Jersey. He has taught English, research methods, creative writing, and seminars on AI for both students and faculty.
            </p>
            <p style="margin: 0 0 24px;">
              His creative work moves between poetry, critical essays on craft, and digital projects that live at the edges of authorship and form. He is the creator of
              <a href="https://thebsideofeverything.com" target="_blank" rel="noopener noreferrer" style="color: #f0ece4; text-decoration-color: rgba(240,236,228,0.25);">The B-Side of Everything</a>, a web archive of music writing curated by TL Skinsbury, and
              <a href="https://whoisrowanblack.com" target="_blank" rel="noopener noreferrer" style="color: #f0ece4; text-decoration-color: rgba(240,236,228,0.25);">The Collected Works of Rowan Black</a>, a recovered archive of poems and fragments curated by the Corvids Collective.
            </p>
            <div style="height: 1px; background: rgba(240,236,228,0.06); margin: 36px 0;"></div>
            <p style="margin: 0;">
              <a href="mailto:contact@jonathanmkelly.com" style="color: rgba(240,236,228,0.5); text-decoration: none; font-family: var(--mono); font-size: 14px; letter-spacing: 0.02em;">contact@jonathanmkelly.com</a>
            </p>
          </div>
        </div>
      </div>
    </main>

    <footer style="padding: 0 var(--page-pad) 60px; text-align: center;">
      <span style="font-family: var(--mono); font-size: 11px; color: rgba(240,236,228,0.15);">&copy; 2026 Jonathan M. Kelly</span>
    </footer>
  </div>
</BaseLayout>
