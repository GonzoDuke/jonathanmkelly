---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parseMetrolined } from '../data/poems/metrolined.js';

const { stanzas, final } = parseMetrolined();
const year = '1999';

// Daytime landscape drifters in three parallax layers.
// Each layer drifts right-to-left; near moves fastest, far barely moves.
// Shape pool is rotated seed-deterministically so the procession mixes
// tall trees, shorter trees, and power poles without obvious repetition.
const SHAPES = [
  'smokestack',
  'water-tower',
  'building-tall',
  'building-low',
  'pole',
  'crane',
  'billboard',
  'signal-mast',
  'tank-round',
] as const;
type ShapeName = typeof SHAPES[number];

function drifters(count: number, layer: 'far' | 'mid' | 'near', seedBase: number) {
  return Array.from({ length: count }).map((_, i) => {
    const seed = (i * 139) + seedBase;
    const shape: ShapeName = SHAPES[seed % SHAPES.length];
    const topOffsetPct =
      layer === 'far'  ? 44 + ((seed * 3) % 8)
    : layer === 'mid'  ? 58 + ((seed * 5) % 10)
    :                    70 + ((seed * 7) % 12);   // near
    const durationBase =
      layer === 'far'  ? 54
    : layer === 'mid'  ? 34
    :                    18;                       // near
    const duration = (durationBase + ((seed * 4) % 14)).toFixed(1);
    const delay    = ((i * (durationBase / count)) + ((seed * 2) % 7)).toFixed(2);
    const scaleBase =
      layer === 'far'  ? 0.45
    : layer === 'mid'  ? 0.8
    :                    1.15;
    const scale = (scaleBase + ((seed % 5) * 0.05)).toFixed(2);
    return { shape, topOffsetPct, duration, delay, scale, layer };
  });
}

const farDrifters  = drifters(4,  'far',  17);
const midDrifters  = drifters(7,  'mid',  53);
const nearDrifters = drifters(10, 'near', 89);

// Lightweight horizontal light streaks — wisps of cloud / sun-glint
const STREAK_COUNT = 4;
const streaks = Array.from({ length: STREAK_COUNT }).map((_, i) => {
  const seed = (i * 211) + 7;
  return {
    topPct: ((seed * 13) % 30) + 10,
    delay: (i * 4.5 + (seed % 9)).toFixed(1),
    duration: (26 + (seed % 12)).toFixed(1),
    width: 180 + (seed % 220),
  };
});
---
<PoetryLayout
  title="Metrolined — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/metrolined"
>
  <div class="mt-page">
    <!-- The scene: everything visible through the window clipped to the
         window's bounds. Sun, streaks, drifters, and rails all ride here. -->
    <div class="mt-scene" aria-hidden="true">
      <div class="mt-sun"></div>

      <!-- Cloud-wisp streaks drifting high across the sky -->
      <div class="mt-streaks" aria-hidden="true">
      {streaks.map((s) => (
        <span
          class="mt-streak"
          style={`
            top: ${s.topPct}%;
            width: ${s.width}px;
            --mt-delay: ${s.delay}s;
            --mt-duration: ${s.duration}s;
          `}
        />
      ))}
    </div>

    <!-- Three parallax layers of passing landscape silhouettes -->
    <div class="mt-drifters" aria-hidden="true">
      {[...farDrifters, ...midDrifters, ...nearDrifters].map((d) => (
        <span
          class={`mt-drifter mt-drifter-${d.layer} mt-shape-${d.shape}`}
          style={`
            top: ${d.topOffsetPct}%;
            --mt-delay: ${d.delay}s;
            --mt-duration: ${d.duration}s;
            --mt-scale: ${d.scale};
          `}
        >
          {d.shape === 'smokestack' && (
            <svg viewBox="0 0 30 100" xmlns="http://www.w3.org/2000/svg">
              <!-- drifting smoke puffs above stack -->
              <ellipse cx="16" cy="6"  rx="9" ry="5" opacity="0.45" />
              <ellipse cx="11" cy="12" rx="7" ry="4" opacity="0.55" />
              <!-- top cap -->
              <rect x="9" y="14" width="12" height="5" />
              <!-- stack body -->
              <rect x="11" y="18" width="8" height="82" />
              <!-- band near base -->
              <rect x="9" y="40" width="12" height="3" />
            </svg>
          )}
          {d.shape === 'water-tower' && (
            <svg viewBox="0 0 40 100" xmlns="http://www.w3.org/2000/svg">
              <!-- cone roof -->
              <path d="M 4 20 L 20 4 L 36 20 Z" />
              <!-- tank sides -->
              <rect x="4" y="20" width="32" height="22" />
              <!-- tank bottom -->
              <ellipse cx="20" cy="42" rx="16" ry="4" />
              <!-- leg frame -->
              <path d="M 6 42 L 34 100" stroke="currentColor" stroke-width="2" fill="none" />
              <path d="M 34 42 L 6 100" stroke="currentColor" stroke-width="2" fill="none" />
              <path d="M 20 42 L 20 100" stroke="currentColor" stroke-width="2" fill="none" />
              <!-- cross braces -->
              <line x1="10" y1="68" x2="30" y2="68" stroke="currentColor" stroke-width="1.2" />
              <line x1="13" y1="86" x2="27" y2="86" stroke="currentColor" stroke-width="1.2" />
            </svg>
          )}
          {d.shape === 'building-tall' && (
            <svg viewBox="0 0 44 100" xmlns="http://www.w3.org/2000/svg">
              <!-- main block -->
              <rect x="0" y="10" width="44" height="90" />
              <!-- rooftop service box -->
              <rect x="10" y="0" width="10" height="12" />
              <rect x="28" y="4" width="6"  height="8" />
              <!-- vertical floor-lines as a subtle texture -->
              <g stroke="rgba(255,255,255,0.08)" stroke-width="1">
                <line x1="7"  y1="16" x2="7"  y2="98" />
                <line x1="17" y1="16" x2="17" y2="98" />
                <line x1="27" y1="16" x2="27" y2="98" />
                <line x1="37" y1="16" x2="37" y2="98" />
              </g>
            </svg>
          )}
          {d.shape === 'building-low' && (
            <svg viewBox="0 0 80 50" xmlns="http://www.w3.org/2000/svg">
              <!-- sawtooth factory roof -->
              <path d="M 0 10 L 10 0 L 20 10 L 30 0 L 40 10 L 50 0 L 60 10 L 70 0 L 80 10 L 80 50 L 0 50 Z" />
              <!-- loading-dock door hint -->
              <rect x="28" y="34" width="10" height="16" fill="rgba(255,255,255,0.08)" />
              <rect x="44" y="34" width="10" height="16" fill="rgba(255,255,255,0.08)" />
            </svg>
          )}
          {d.shape === 'pole' && (
            <svg viewBox="0 0 40 100" xmlns="http://www.w3.org/2000/svg">
              <rect x="18" y="8" width="4" height="92" />
              <rect x="4"  y="16" width="32" height="2" />
              <rect x="8"  y="14" width="2" height="6" />
              <rect x="18" y="12" width="2" height="4" />
              <rect x="30" y="14" width="2" height="6" />
              <rect x="6"  y="28" width="28" height="2" />
            </svg>
          )}
          {d.shape === 'crane' && (
            <svg viewBox="0 0 70 120" xmlns="http://www.w3.org/2000/svg">
              <!-- tower mast -->
              <rect x="30" y="36" width="4" height="84" />
              <!-- lattice Xs on the mast -->
              <g stroke="currentColor" stroke-width="0.8" fill="none">
                <path d="M 30 48 L 34 58 M 34 48 L 30 58" />
                <path d="M 30 70 L 34 80 M 34 70 L 30 80" />
                <path d="M 30 92 L 34 102 M 34 92 L 30 102" />
              </g>
              <!-- horizontal jib (long, forward) -->
              <rect x="0" y="32" width="68" height="4" />
              <!-- operator cab -->
              <rect x="26" y="24" width="14" height="12" />
              <!-- counter-jib ballast -->
              <rect x="2" y="26" width="14" height="10" />
              <!-- hoist cable + block -->
              <line x1="56" y1="36" x2="56" y2="74" stroke="currentColor" stroke-width="1" />
              <rect x="53" y="72" width="6" height="5" />
            </svg>
          )}
          {d.shape === 'billboard' && (
            <svg viewBox="0 0 64 100" xmlns="http://www.w3.org/2000/svg">
              <!-- panel -->
              <rect x="0"  y="28" width="64" height="28" />
              <!-- top trim -->
              <rect x="0"  y="26" width="64" height="2" />
              <!-- peeling poster hint -->
              <rect x="8"  y="34" width="22" height="14" opacity="0.28" fill="rgba(255,255,255,0.3)" />
              <!-- support legs -->
              <rect x="12" y="56" width="3" height="44" />
              <rect x="49" y="56" width="3" height="44" />
              <!-- diagonal brace -->
              <line x1="14" y1="70" x2="50" y2="92" stroke="currentColor" stroke-width="1" />
            </svg>
          )}
          {d.shape === 'signal-mast' && (
            <svg viewBox="0 0 30 110" xmlns="http://www.w3.org/2000/svg">
              <!-- vertical mast -->
              <rect x="13" y="24" width="3" height="86" />
              <!-- mount crossarm -->
              <rect x="6" y="26" width="20" height="2" />
              <!-- stacked signal heads -->
              <circle cx="20" cy="10" r="4" />
              <circle cx="20" cy="20" r="4" />
              <!-- ladder rails -->
              <rect x="10" y="38" width="1" height="62" />
              <rect x="18" y="38" width="1" height="62" />
              <!-- ladder rungs -->
              <g stroke="currentColor" stroke-width="0.8">
                <line x1="10" y1="46" x2="19" y2="46" />
                <line x1="10" y1="58" x2="19" y2="58" />
                <line x1="10" y1="70" x2="19" y2="70" />
                <line x1="10" y1="82" x2="19" y2="82" />
                <line x1="10" y1="94" x2="19" y2="94" />
              </g>
            </svg>
          )}
          {d.shape === 'tank-round' && (
            <svg viewBox="0 0 80 70" xmlns="http://www.w3.org/2000/svg">
              <!-- spherical oil-tank dome -->
              <path d="M 6 60 Q 6 18 40 14 Q 74 18 74 60 Z" />
              <!-- support base -->
              <rect x="2" y="58" width="76" height="8" />
              <!-- side ladder -->
              <rect x="40" y="20" width="1" height="38" />
              <g stroke="currentColor" stroke-width="0.7">
                <line x1="38" y1="26" x2="42" y2="26" />
                <line x1="38" y1="34" x2="42" y2="34" />
                <line x1="38" y1="42" x2="42" y2="42" />
                <line x1="38" y1="50" x2="42" y2="50" />
              </g>
              <!-- small top vent -->
              <rect x="38" y="10" width="4" height="6" />
            </svg>
          )}
        </span>
      ))}
    </div>

    </div>

    <!-- Train window frame + cabin interior bleed -->
    <div class="mt-window" aria-hidden="true">
      <div class="mt-window-frame"></div>
      <div class="mt-window-cabin"></div>
    </div>

    <nav class="mt-nav">
      <a href="/" class="mt-brand">JMK</a>
      <div class="mt-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="mt-article">
      <header class="mt-masthead">
        <a href="/poetry" class="mt-back">&larr; Poetry</a>
        <p class="mt-year">{year}</p>
        <h1 class="mt-title">Metrolined</h1>
      </header>

      <div class="mt-body">
        {stanzas.map((stanza) => (
          <p class="mt-stanza">
            {stanza.map((line, i) => (
              <Fragment>
                {line}
                {i < stanza.length - 1 && <br />}
              </Fragment>
            ))}
          </p>
        ))}

        <p class="mt-stanza mt-final" data-trigger="stop">
          {final.map((line, i) => (
            <Fragment>
              {line}
              {i < final.length - 1 && <br />}
            </Fragment>
          ))}
        </p>
      </div>

      <footer class="mt-footer">
        <a href="/poetry" class="mt-next">
          <span class="mt-next-label">&larr; Return to</span>
          <span class="mt-next-title">Poetry</span>
        </a>
      </footer>
    </article>
  </div>

  <style is:global>
    .mt-page {
      --mt-cabin: #2A1F14;
      --mt-cabin-deep: #1A130B;
      --mt-sky-top: #B8CEDE;
      --mt-sky-mid: #D6C8A8;
      --mt-sky-low: #E4CFA0;
      --mt-horizon: #A89268;
      --mt-text: #1A140A;
      --mt-muted: rgba(26, 20, 10, 0.55);
      --mt-gold: #8B6A2A;
      --mt-gold-soft: rgba(139, 106, 42, 0.75);
      --mt-near:  #14100A;
      --mt-mid:   rgba(72, 58, 48, 0.82);
      --mt-far:   rgba(96, 110, 120, 0.56);
      background:
        radial-gradient(ellipse 140vw 80vh at 50% 50%,
          #3A2A1A 0%,
          var(--mt-cabin) 55%,
          var(--mt-cabin-deep) 100%);
      color: var(--mt-text);
      min-height: 100vh;
      position: relative;
      font-family: 'Times New Roman', Times, 'Liberation Serif', serif;
      overflow-x: hidden;
    }

    /* ── Scene — everything the passenger sees through the window.
       Positioned with the same inset as the window frame, overflow-
       hidden + rounded corners so all motion is clipped to the glass. ── */
    .mt-scene {
      position: fixed;
      inset: clamp(88px, 13vh, 140px)
             clamp(72px, 10vw, 160px)
             clamp(140px, 20vh, 200px);
      border-radius: 10px;
      overflow: hidden;
      pointer-events: none;
      z-index: 0;
      background:
        linear-gradient(to bottom,
          var(--mt-sky-top) 0%,
          #CBD1C6 38%,
          var(--mt-sky-mid) 64%,
          var(--mt-sky-low) 82%,
          var(--mt-horizon) 100%);
    }
    /* Sun glow — bright radial inside the scene */
    .mt-sun {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle 42vh at 22% 18%,
          rgba(255, 238, 200, 0.85) 0%,
          rgba(255, 220, 150, 0.35) 28%,
          rgba(255, 200, 120, 0.12) 55%,
          transparent 75%);
      mix-blend-mode: screen;
      pointer-events: none;
    }

    /* ── Train-window frame: dark cabin-wood edges against bright sky ── */
    .mt-window {
      position: fixed;
      inset: clamp(88px, 13vh, 140px)
             clamp(72px, 10vw, 160px)
             clamp(140px, 20vh, 200px);
      pointer-events: none;
      z-index: 3;
    }
    .mt-window-frame {
      position: absolute;
      inset: 0;
      border-radius: 10px;
      box-shadow:
        0 0 0 1px rgba(20, 12, 6, 0.82),
        0 0 0 5px var(--mt-cabin),
        0 0 0 7px rgba(12, 8, 4, 0.6),
        inset 0 0 80px rgba(28, 20, 12, 0.18),
        inset 0 0 1px rgba(80, 60, 36, 0.4);
    }
    /* Cabin interior warmth bleeds into the edges of the view */
    .mt-window-cabin {
      position: absolute;
      inset: -clamp(88px, 13vh, 140px)
             -clamp(72px, 10vw, 160px)
             -clamp(140px, 20vh, 200px);
      background:
        radial-gradient(ellipse 44vw 32vh at 0% 50%,
          rgba(60, 40, 20, 0.45) 0%, transparent 50%),
        radial-gradient(ellipse 44vw 32vh at 100% 50%,
          rgba(60, 40, 20, 0.45) 0%, transparent 50%),
        radial-gradient(ellipse 80vw 24vh at 50% 0%,
          rgba(38, 24, 12, 0.35) 0%, transparent 55%),
        radial-gradient(ellipse 80vw 24vh at 50% 100%,
          rgba(38, 24, 12, 0.4) 0%, transparent 55%);
      z-index: -1;
    }

    /* ── Drifting landscape silhouettes (3 parallax layers) ──
       Positioned inside the scene so they're clipped to the window. ── */
    .mt-drifters {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }
    .mt-drifter {
      position: absolute;
      right: -80px;
      transform: translate3d(0, -100%, 0) scale(var(--mt-scale, 1));
      transform-origin: bottom center;
      animation: mt-drift var(--mt-duration, 26s) linear infinite;
      animation-delay: var(--mt-delay, 0s);
      will-change: transform;
    }
    .mt-drifter svg {
      display: block;
      height: 100%;
      width: auto;
    }
    /* All drifter shapes inherit layer color via currentColor so both
       fill and stroke pick up the right tone per layer. */
    .mt-drifter svg path:not([fill]),
    .mt-drifter svg rect:not([fill]),
    .mt-drifter svg ellipse:not([fill]) {
      fill: currentColor;
    }

    /* Far layer: distant industrial haze, faint blue-gray */
    .mt-drifter-far {
      height: clamp(48px, 7vh, 72px);
      color: var(--mt-far);
    }
    /* Mid layer: warehouses / brick, warm gray-brown */
    .mt-drifter-mid {
      height: clamp(64px, 10vh, 104px);
      color: var(--mt-mid);
    }
    /* Near layer: close rooflines + utility poles, near-black */
    .mt-drifter-near {
      height: clamp(96px, 14vh, 148px);
      color: var(--mt-near);
    }
    @keyframes mt-drift {
      0%   { transform: translate3d(0, -100%, 0) scale(var(--mt-scale, 1)); }
      100% { transform: translate3d(calc(-100vw - 200px), -100%, 0) scale(var(--mt-scale, 1)); }
    }
    .mt-page.is-stopped .mt-drifter { animation-play-state: paused; }

    /* ── Cloud-wisp streaks high in the sky (inside scene) ── */
    .mt-streaks {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }
    .mt-streak {
      position: absolute;
      right: -240px;
      height: 2px;
      background: linear-gradient(
        to left,
        rgba(255, 248, 230, 0) 0%,
        rgba(255, 248, 230, 0.55) 30%,
        rgba(255, 248, 230, 0.55) 70%,
        rgba(255, 248, 230, 0) 100%);
      filter: blur(1px);
      opacity: 0;
      animation: mt-streak var(--mt-duration, 30s) linear infinite;
      animation-delay: var(--mt-delay, 0s);
      will-change: transform, opacity;
    }
    @keyframes mt-streak {
      0%   { transform: translateX(0); opacity: 0; }
      15%  { opacity: 0.55; }
      65%  { opacity: 0.4; }
      95%  { opacity: 0.15; }
      100% { transform: translateX(calc(-100vw - 500px)); opacity: 0; }
    }
    .mt-page.is-stopped .mt-streak { animation-play-state: paused; }

    /* ── Nav (sits inside the cabin, above the window) ── */
    .mt-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(20, 14, 8, 0.9);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(60, 42, 22, 0.55);
      padding: 0 var(--page-pad);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .mt-brand {
      font-family: 'Times New Roman', Times, serif;
      font-size: 22px;
      font-style: italic;
      font-weight: 400;
      color: #F0E6D2;
      text-decoration: none;
    }
    .mt-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .mt-nav-links a {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: rgba(240, 230, 210, 0.48);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .mt-nav-links a:hover { color: var(--mt-gold); }
    .mt-nav-links a.is-current { color: rgba(240, 230, 210, 0.9); }

    /* ── Article ── */
    .mt-article {
      max-width: 600px;
      margin: 0 auto;
      padding: 124px var(--page-pad) 160px;
      position: relative;
      z-index: 10;
      text-align: center;
    }

    /* ── Masthead ── */
    .mt-masthead { margin-bottom: 72px; text-align: center; }
    .mt-back {
      display: inline-block;
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(26, 20, 10, 0.5);
      text-decoration: none;
      margin-bottom: 56px;
      transition: color 0.3s ease;
      text-shadow:
        0 0 2px rgba(240, 232, 214, 0.9),
        0 0 10px rgba(240, 232, 214, 0.5);
    }
    .mt-back:hover { color: var(--mt-gold); }
    .mt-year {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--mt-gold);
      margin: 0 0 22px;
      text-shadow:
        0 0 2px rgba(240, 232, 214, 0.9),
        0 0 10px rgba(240, 232, 214, 0.5);
    }
    .mt-title {
      font-family: 'Times New Roman', Times, 'Liberation Serif', serif;
      font-style: italic;
      font-size: clamp(52px, 8vw, 78px);
      font-weight: 400;
      line-height: 1.02;
      color: #14100A;
      margin: 0 0 20px;
      text-shadow:
        0 0 4px rgba(240, 232, 214, 0.9),
        0 0 26px rgba(240, 232, 214, 0.55);
    }

    /* ── Body — slab serif (Arvo 700), centered, heavy enough to read
       cleanly over sky + passing silhouettes. ── */
    .mt-body {
      font-family: var(--poetry-slab);
      font-weight: 700;
      font-size: 18px;
      line-height: 1.62;
      color: #120D06;
      text-align: center;
      letter-spacing: -0.005em;
      text-shadow:
        0 0 2px rgba(240, 232, 214, 0.95),
        0 0 14px rgba(240, 232, 214, 0.7);
    }
    .mt-stanza {
      white-space: pre-wrap;
      margin: 0 0 30px;
      font-family: inherit;
    }
    .mt-stanza:last-child { margin-bottom: 0; }
    /* Final stanza — train has arrived, air opens up around it.
       Slightly larger and warmer than body, kept non-italic so the
       Arvo 700 weight reads without synthesized italic fallback. */
    .mt-final {
      margin-top: 68px;
      padding-top: 30px;
      color: #0C0804;
      font-size: 20px;
      letter-spacing: -0.008em;
      border-top: 1px solid rgba(80, 58, 30, 0.45);
    }

    /* ── Footer ── */
    .mt-footer {
      margin-top: 120px;
      padding-top: 40px;
      border-top: 1px solid rgba(80, 58, 30, 0.35);
      text-align: center;
    }
    .mt-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 10px;
      color: var(--mt-text);
      transition: color 0.3s ease;
    }
    .mt-next-label {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--mt-gold);
      text-shadow:
        0 0 2px rgba(240, 232, 214, 0.85),
        0 0 10px rgba(240, 232, 214, 0.4);
    }
    .mt-next-title {
      font-family: 'Times New Roman', Times, serif;
      font-style: italic;
      font-weight: 400;
      font-size: clamp(26px, 3.4vw, 32px);
      line-height: 1.2;
      color: #14100A;
      text-shadow:
        0 0 2px rgba(240, 232, 214, 0.9),
        0 0 14px rgba(240, 232, 214, 0.55);
    }
    .mt-next:hover .mt-next-title { color: var(--mt-gold); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .mt-article { padding: 112px var(--page-pad) 120px; }
      .mt-masthead { margin-bottom: 56px; }
      .mt-back { margin-bottom: 40px; }
      .mt-body { font-size: 16.5px; line-height: 1.6; }
      .mt-final { margin-top: 48px; padding-top: 24px; font-size: 18px; }
      .mt-footer { margin-top: 80px; }
      .mt-scene,
      .mt-window { inset: 96px 16px 132px; }
      .mt-window-cabin { inset: -96px -16px -132px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .mt-drifter, .mt-streak {
        animation: none;
        transform: translate3d(-45vw, -100%, 0) scale(var(--mt-scale, 1));
        opacity: 0.7;
      }
      .mt-streak { transform: translateX(-45vw); }
    }
  </style>

  <script>
    const page = document.querySelector<HTMLElement>('.mt-page');
    const final = document.querySelector<HTMLElement>('[data-trigger="stop"]');
    if (page && final && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) page.classList.add('is-stopped');
          else page.classList.remove('is-stopped');
        });
      }, { threshold: 0.45 });
      io.observe(final);
    }
  </script>
</PoetryLayout>
