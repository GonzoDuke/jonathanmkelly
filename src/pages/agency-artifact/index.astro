---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { AA_PIECES } from '../../data/pieces.js';

const livePieces = AA_PIECES.filter(p => p.status === 'live');
---

<BaseLayout title="Agency & Artifact — Jonathan M. Kelly" description="Writing clearly in a system built for noise." ogUrl="https://www.jonathanmkelly.com/agency-artifact">
  <div style="background: #f0f2f5; min-height: 100vh;">
    <!-- Nav -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: #1b2332;
      padding: 0 var(--page-pad);
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    `}>
      <a href="/" style={`
        font-family: var(--serif); font-size: 20px; font-weight: 500;
        color: #e0e4ec; text-decoration: none; letter-spacing: -0.01em;
      `}>JMK</a>
      <div style="display: flex; gap: clamp(20px, 3vw, 36px); align-items: center; flex-wrap: wrap;">
        <a href="/projects" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(224,228,236,0.4); text-decoration: none;">Projects</a>
        <a href="/detourist" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(224,228,236,0.4); text-decoration: none;">detourist</a>
        <a href="/poetry" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(224,228,236,0.4); text-decoration: none;">Poetry</a>
        <a href="/agency-artifact" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(224,228,236,0.8); text-decoration: none;">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(224,228,236,0.4); text-decoration: none;">Contact</a>
        <a href="/about" style="font-family: var(--mono); font-size: 13px; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(224,228,236,0.4); text-decoration: none;">About</a>
        <button
          class="share-btn"
          data-title="Agency & Artifact"
          data-text="Writing clearly in a system built for noise. By Jonathan M. Kelly"
          data-url="https://www.jonathanmkelly.com/agency-artifact"
          style={`
            background: none; border: 1px solid rgba(255,255,255,0.15);
            border-radius: 3px; padding: 5px 12px; cursor: pointer;
            font-family: var(--mono); font-size: 10px; font-weight: 400;
            letter-spacing: 0.06em; text-transform: uppercase;
            color: rgba(255,255,255,0.35); transition: all 0.2s ease;
          `}>Share</button>
      </div>
    </nav>

    <!-- Full-width dark header -->
    <header style="background: #1b2332; color: #e0e4ec; padding: 100px var(--page-pad) 56px;">
      <div style="max-width: 900px; margin: 0 auto;">
        <h1 style={`
          font-family: var(--serif); font-size: clamp(44px, 7vw, 72px);
          font-weight: 400; line-height: 1.0; color: #e0e4ec;
          letter-spacing: -0.025em; margin: 0 0 18px;
        `}>Agency &amp; Artifact</h1>
        <p style={`
          font-family: var(--body); font-size: 18px; font-style: italic;
          color: rgba(224,228,236,0.4); line-height: 1.55;
          margin: 0; max-width: 460px;
        `}>Writing clearly in a system built for noise.</p>
      </div>
    </header>

    <!-- Piece list on white card -->
    <main style="max-width: 980px; margin: 0 auto; padding: 0 var(--page-pad);">
      <div style={`
        background: #ffffff;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06), 0 12px 32px rgba(0,0,0,0.04);
        padding: clamp(32px, 4vw, 48px);
        max-width: 900px; margin: 0 auto;
      `}>
        {livePieces.map((piece) => (
          <a href={`/agency-artifact/${piece.id}`} style={`
            display: block; padding: 24px 0;
            border-bottom: 1px solid rgba(0,0,0,0.06);
            text-decoration: none;
          `}>
            <div style={`
              font-family: var(--serif); font-size: 24px; font-weight: 400;
              color: #1a1d28; line-height: 1.25; margin-bottom: 6px;
            `}>{piece.title}</div>
            {piece.subtitle && (
              <div style={`
                font-family: var(--body); font-size: 15px; font-style: italic;
                color: #6a7088; line-height: 1.5;
              `}>{piece.subtitle}</div>
            )}
          </a>
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer style="max-width: 900px; margin: 0 auto; padding: 56px var(--page-pad) 100px; text-align: center;">
      <a href="/" style={`
        font-family: var(--mono); font-size: 12px; font-weight: 400;
        letter-spacing: 0.04em; color: #8a94a8; text-decoration: none;
      `}>&larr; Back</a>
    </footer>
  </div>
  <script>
    document.querySelectorAll('.share-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const data = { title: btn.dataset.title, text: btn.dataset.text, url: btn.dataset.url };
        if (navigator.share) {
          try { await navigator.share(data); } catch {}
        } else {
          await navigator.clipboard.writeText(data.url);
          btn.textContent = 'Copied';
          setTimeout(() => { btn.textContent = 'Share'; }, 1500);
        }
      });
    });
  </script>
</BaseLayout>
