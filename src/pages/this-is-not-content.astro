---
import PieceLayout from '../layouts/PieceLayout.astro';
import { PIECES } from '../data/pieces.js';
import ThisIsNotContent from '../components/pieces/poems/ThisIsNotContent.jsx';

const piece = PIECES.find(p => p.id === 'this-is-not-content');
---

<PieceLayout piece={piece}>
  <ThisIsNotContent client:load />
</PieceLayout>
