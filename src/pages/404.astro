---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found — Jonathan M. Kelly">
  <div style="background: #0c0c0c; min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div style="text-align: center; padding: var(--page-pad);">
      <div style={`
        font-family: var(--serif); font-size: clamp(80px, 15vw, 200px);
        font-weight: 300; color: rgba(240,236,228,0.06);
        line-height: 0.9; margin-bottom: 24px;
      `}>404</div>
      <p style={`
        font-family: var(--body); font-size: 20px;
        color: rgba(240,236,228,0.4); margin-bottom: 32px;
      `}>Nothing here.</p>
      <a href="/" style={`
        font-family: var(--mono); font-size: 12px; font-weight: 400;
        letter-spacing: 0.04em; color: rgba(240,236,228,0.35); text-decoration: none;
      `}>&larr; Back</a>
    </div>
  </div>
</BaseLayout>
