---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found — Jonathan M. Kelly">
  <div style="background: var(--bg); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div style="text-align: center; padding: var(--page-pad);">
      <div style={`
        font-family: var(--mono); font-size: 11px; font-weight: 300;
        color: var(--ghost); letter-spacing: 0.1em; margin-bottom: 16px;
      `}>404</div>
      <h1 style={`
        font-family: var(--serif); font-size: 28px; font-weight: 400;
        color: var(--text); margin: 0 0 20px;
      `}>Nothing here.</h1>
      <a href="/" style={`
        font-family: var(--mono); font-size: 11px; font-weight: 400;
        letter-spacing: 0.04em; color: var(--dim); text-decoration: none;
      `}>&larr; Back</a>
    </div>
  </div>
</BaseLayout>
