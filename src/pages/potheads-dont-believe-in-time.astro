---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parsePotheads } from '../data/poems/potheads-dont-believe-in-time.js';

const sections = parsePotheads();
const year = '2024';
const next = { slug: 'briefcase-full-of-rainbows', title: 'Briefcase Full of Rainbows' };

// Time-marker ghosts — stray years floating in the room, pulled from the
// poem itself. Low-opacity italic, fixed scattered positions.
const TIME_GHOSTS = [
  { year: '1977', top: '18%',  left: '8%',   delay: '0s'    },
  { year: '1989', top: '62%',  left: '5%',   delay: '1.8s'  },
  { year: '1991', top: '82%',  left: '18%',  delay: '3.2s'  },
  { year: '1995', top: '28%',  left: '86%',  delay: '0.7s'  },
  { year: '2000', top: '68%',  left: '78%',  delay: '2.4s'  },
  { year: '2007', top: '44%',  left: '3%',   delay: '4.1s'  },
  { year: '2021', top: '8%',   left: '74%',  delay: '5.3s'  },
];

// Slow smoke-drift particles rising from below the viewport
const SMOKE_COUNT = 9;
const smokeParticles = Array.from({ length: SMOKE_COUNT }).map((_, i) => {
  const seed = (i * 71) + 19;
  return {
    leftPct: ((seed * 7) % 96) + 2,
    delay: (i * 2.7 + (seed % 9)).toFixed(1),
    duration: (22 + ((seed * 5) % 18)).toFixed(1),
    size: 160 + ((seed * 3) % 180),
  };
});
---
<PoetryLayout
  title="Potheads Don't Believe in Time — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/potheads-dont-believe-in-time"
>
  <div class="po-page" data-stage="I">
    <!-- Ambient warm cast from the lamp into the room -->
    <div class="po-lamp-cast" aria-hidden="true"></div>

    <!-- Slow drifting smoke haze rising through the room -->
    <div class="po-smoke" aria-hidden="true">
      {smokeParticles.map((p) => (
        <span
          class="po-smoke-wisp"
          style={`
            left: ${p.leftPct}%;
            width: ${p.size}px;
            height: ${p.size}px;
            --po-delay: ${p.delay}s;
            --po-duration: ${p.duration}s;
          `}
        />
      ))}
    </div>

    <!-- Scattered time-marker ghosts — years pulled from the poem -->
    <div class="po-ghosts" aria-hidden="true">
      {TIME_GHOSTS.map((g) => (
        <span
          class="po-ghost"
          style={`top: ${g.top}; left: ${g.left}; --po-delay: ${g.delay};`}
        >{g.year}</span>
      ))}
    </div>

    <!-- CRT scan overlay — only visible during Section III (internet) -->
    <div class="po-scanlines" aria-hidden="true"></div>

    <!-- Lava lamp — fixed bottom-right. Glass bulb shape clips the
         canvas; canvas holds the metaball blobs (filter applied on
         the wrapper to produce the liquid merging look). -->
    <div class="po-lamp" aria-hidden="true">
      <!-- Static silhouette fallback for reduced-motion -->
      <svg class="po-lamp-silhouette" viewBox="0 0 120 260" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="po-lamp-glass" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"  stop-color="#3C160A" stop-opacity="0.9" />
            <stop offset="55%" stop-color="#5A2010" stop-opacity="0.85" />
            <stop offset="100%" stop-color="#2A0E06" stop-opacity="0.9" />
          </linearGradient>
          <radialGradient id="po-lamp-blob" cx="50%" cy="50%" r="50%">
            <stop offset="0%"  stop-color="#FFB066" stop-opacity="0.95" />
            <stop offset="50%" stop-color="#FF5522" stop-opacity="0.8" />
            <stop offset="100%" stop-color="#B0300A" stop-opacity="0" />
          </radialGradient>
          <!-- Exact glass-bulb clip — matches the bulb SVG path, normalized
               to the .po-lamp-bulb div's local 0-1 space so no canvas
               content can leak outside the glass contour. -->
          <clipPath id="po-lamp-bulb-clip" clipPathUnits="objectBoundingBox">
            <path d="M 0.30 0
                     Q -0.075 0.29 0 0.67
                     Q 0.075 0.96 0.50 1.00
                     Q 0.925 0.96 1.00 0.67
                     Q 1.075 0.29 0.70 0
                     Z" />
          </clipPath>
        </defs>
        <!-- cap -->
        <rect x="38" y="4" width="44" height="14" rx="3" fill="#1E0F07" />
        <!-- top tapered neck -->
        <path d="M 42 18 L 78 18 L 72 36 L 48 36 Z" fill="#1E0F07" />
        <!-- bulb body -->
        <path d="M 44 36 Q 14 96 20 174 Q 26 234 60 242 Q 94 234 100 174 Q 106 96 76 36 Z"
              fill="url(#po-lamp-glass)" />
        <!-- base -->
        <path d="M 30 240 L 90 240 L 84 256 L 36 256 Z" fill="#1E0F07" />
        <!-- static blobs for reduced-motion -->
        <circle class="po-lamp-static-blob" cx="54" cy="170" r="24" fill="url(#po-lamp-blob)" />
        <circle class="po-lamp-static-blob" cx="68" cy="120" r="18" fill="url(#po-lamp-blob)" />
        <circle class="po-lamp-static-blob" cx="48" cy="80"  r="14" fill="url(#po-lamp-blob)" />
      </svg>
      <!-- Animated metaball canvas, clipped to the bulb region -->
      <div class="po-lamp-bulb">
        <canvas class="po-lamp-canvas"></canvas>
      </div>
    </div>

    <nav class="po-nav">
      <a href="/" class="po-brand">JMK</a>
      <div class="po-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="po-article">
      <header class="po-masthead">
        <a href="/poetry" class="po-back">&larr; Poetry</a>
        <p class="po-year">{year}</p>
        <h1 class="po-title">Potheads Don&rsquo;t Believe in Time</h1>
      </header>

      <div class="po-body">
        {sections.map((section) => (
          <section class="po-section" data-stage={section.numeral}>
            <h2 class="po-section-head">
              <span class="po-numeral">{section.numeral === 'Coda' ? 'Coda.' : `${section.numeral}.`}</span>
            </h2>
            {section.stanzas.map((stanza) => (
              <p class="po-stanza">{stanza.map((line, li) => (
                <Fragment>
                  {line}
                  {li < stanza.length - 1 && '\n'}
                </Fragment>
              ))}</p>
            ))}
          </section>
        ))}
      </div>

      <footer class="po-footer">
        <a href={`/${next.slug}`} class="po-next">
          <span class="po-next-label">Next poem &rarr;</span>
          <span class="po-next-title">{next.title}</span>
        </a>
      </footer>
    </article>
  </div>

  <style is:global>
    .po-page {
      /* Stage-keyed color temperature. The default is Stage I (basement
         amber). Other stages override via [data-stage] selectors. */
      --po-bg: #1A0E08;
      --po-bg-deep: #0E0604;
      --po-text: #F4EBD4;
      --po-muted: rgba(244, 235, 212, 0.52);
      --po-accent: #FF7A32;
      --po-lamp-body: #2A0E06;
      background:
        radial-gradient(ellipse 120vw 80vh at 50% 40%,
          #241208 0%,
          var(--po-bg) 55%,
          var(--po-bg-deep) 100%);
      color: var(--po-text);
      min-height: 100vh;
      position: relative;
      font-family: var(--serif);
      overflow-x: hidden;
      transition: background 2.2s ease, color 2.2s ease;
    }
    /* Stage II — same amber, slightly sepia-shifted */
    .po-page[data-stage="II"]   { --po-bg: #22180E; --po-bg-deep: #120A06;
                                  --po-text: #EADFC4; --po-accent: #FF8A44; }
    /* Stage III — internet / cool blue-white */
    .po-page[data-stage="III"]  { --po-bg: #0A1824; --po-bg-deep: #050C15;
                                  --po-text: #E4ECF4; --po-accent: #6AA0E0; }
    /* Stage IV — back to warm basement */
    .po-page[data-stage="IV"]   { --po-bg: #1A0E08; --po-bg-deep: #0E0604;
                                  --po-text: #F4EBD4; --po-accent: #FF7A32; }
    /* Stage V — basement dimming */
    .po-page[data-stage="V"]    { --po-bg: #140806; --po-bg-deep: #080402;
                                  --po-text: #D8CFB8; --po-accent: #E86428; }
    /* Coda — nearly dark */
    .po-page[data-stage="Coda"] { --po-bg: #07040A; --po-bg-deep: #02010C;
                                  --po-text: #A89A7A; --po-accent: #C45010; }

    .po-page {
      background:
        radial-gradient(ellipse 120vw 80vh at 50% 40%,
          color-mix(in srgb, var(--po-bg), #241208 30%) 0%,
          var(--po-bg) 55%,
          var(--po-bg-deep) 100%);
    }

    /* ── Ambient warm cast from the lamp ── */
    .po-lamp-cast {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      background:
        radial-gradient(ellipse 70vw 80vh at 92% 92%,
          rgba(255, 110, 40, 0.22) 0%,
          rgba(255, 80, 20, 0.10) 30%,
          rgba(200, 50, 10, 0.04) 55%,
          transparent 80%),
        radial-gradient(ellipse 50vw 50vh at 92% 92%,
          rgba(255, 200, 120, 0.14) 0%,
          transparent 70%);
      mix-blend-mode: screen;
      transition: background 2.2s ease, opacity 2.2s ease;
    }
    /* Stage III switches the cast cool — internet-era blue fluorescence */
    .po-page[data-stage="III"] .po-lamp-cast {
      background:
        radial-gradient(ellipse 70vw 80vh at 92% 92%,
          rgba(100, 150, 220, 0.24) 0%,
          rgba(60, 100, 180, 0.12) 32%,
          transparent 80%),
        radial-gradient(ellipse 50vw 50vh at 8% 12%,
          rgba(180, 210, 240, 0.12) 0%,
          transparent 70%);
    }
    .po-page[data-stage="V"]    .po-lamp-cast { opacity: 0.65; }
    .po-page[data-stage="Coda"] .po-lamp-cast { opacity: 0.35; }

    /* ── Slow smoke-haze drift ── */
    .po-smoke {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      overflow: hidden;
    }
    .po-smoke-wisp {
      position: absolute;
      bottom: -180px;
      border-radius: 50%;
      background: radial-gradient(circle,
        rgba(255, 200, 150, 0.28) 0%,
        rgba(255, 180, 130, 0.12) 40%,
        rgba(255, 180, 130, 0) 72%);
      filter: blur(22px);
      opacity: 0;
      animation: po-smoke-rise var(--po-duration, 28s) ease-in-out infinite;
      animation-delay: var(--po-delay, 0s);
      will-change: transform, opacity;
      mix-blend-mode: screen;
    }
    @keyframes po-smoke-rise {
      0%   { transform: translate(0, 0) scale(0.6); opacity: 0; }
      10%  { opacity: 0.28; }
      50%  { transform: translate(60px, -55vh) scale(1.3); opacity: 0.22; }
      90%  { opacity: 0.08; }
      100% { transform: translate(-40px, -115vh) scale(1.8); opacity: 0; }
    }
    .po-page[data-stage="III"] .po-smoke-wisp {
      background: radial-gradient(circle,
        rgba(180, 210, 240, 0.22) 0%,
        rgba(120, 160, 210, 0.1) 40%,
        transparent 72%);
    }
    .po-page[data-stage="V"]    .po-smoke-wisp { opacity: 0; opacity: 0.75; }
    .po-page[data-stage="Coda"] .po-smoke-wisp { filter: blur(30px); opacity: 0.5; }

    /* ── Time ghosts — stray years floating at low opacity ── */
    .po-ghosts {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
    }
    .po-ghost {
      position: absolute;
      transform: translate(-50%, -50%);
      font-family: var(--poetry-classical);
      font-style: italic;
      font-weight: 500;
      font-size: clamp(30px, 5vw, 58px);
      color: var(--po-accent);
      opacity: 0.1;
      letter-spacing: -0.01em;
      animation: po-ghost-pulse 12s ease-in-out infinite;
      animation-delay: var(--po-delay, 0s);
      mix-blend-mode: screen;
      transition: color 2.2s ease;
    }
    @keyframes po-ghost-pulse {
      0%, 100% { opacity: 0.08; transform: translate(-50%, -50%) scale(1); }
      50%      { opacity: 0.22; transform: translate(-50%, -50%) scale(1.04); }
    }
    .po-page[data-stage="Coda"] .po-ghost { opacity: 0.06; }

    /* ── CRT scanlines — only during the internet section ── */
    .po-scanlines {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 4;
      opacity: 0;
      background: repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 2px,
        rgba(130, 170, 220, 0.05) 2.5px,
        rgba(0, 0, 0, 0.14) 3.5px,
        transparent 4.5px
      );
      mix-blend-mode: multiply;
      transition: opacity 1.8s ease;
    }
    .po-page[data-stage="III"] .po-scanlines {
      opacity: 0.7;
      animation: po-scan-roll 14s linear infinite;
    }
    @keyframes po-scan-roll {
      0%   { background-position-y: 0; }
      100% { background-position-y: 64px; }
    }

    /* ── Lava lamp ── */
    .po-lamp {
      position: fixed;
      right: clamp(12px, 2vw, 32px);
      bottom: clamp(12px, 2vh, 36px);
      width: clamp(160px, 20vw, 280px);
      aspect-ratio: 120 / 260;
      z-index: 3;
      pointer-events: none;
      /* Only a dark cast-shadow for physical depth — no warm halo.
         Warmth in the room comes from .po-lamp-cast, not from a glow
         bleeding off the lamp silhouette itself. */
      filter: drop-shadow(0 16px 34px rgba(0, 0, 0, 0.6));
    }
    .po-lamp-silhouette {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .po-lamp-silhouette .po-lamp-static-blob { display: none; }
    .po-lamp-bulb {
      position: absolute;
      /* Corresponds to the bulb region in the SVG viewBox (120x260). */
      left:   calc(100% * 20 / 120);
      right:  calc(100% * 20 / 120);
      top:    calc(100% * 36 / 260);
      bottom: calc(100% * 18 / 260);
      overflow: hidden;
      /* Clip to the exact glass contour so the canvas content can't
         leak out of the bulb rectangle's rounded corners. The SVG
         <clipPath> is defined inside .po-lamp-silhouette above. */
      clip-path: url(#po-lamp-bulb-clip);
      -webkit-clip-path: url(#po-lamp-bulb-clip);
      filter: blur(4px) contrast(22);
      mix-blend-mode: screen;
    }
    .po-lamp-canvas {
      width: 100%;
      height: 100%;
      display: block;
    }

    @media (prefers-reduced-motion: reduce) {
      .po-lamp-bulb { display: none; }
      .po-lamp-silhouette .po-lamp-static-blob { display: block; }
    }

    /* ── Nav ── */
    .po-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: color-mix(in srgb, var(--po-bg) 85%, transparent);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid color-mix(in srgb, var(--po-text) 10%, transparent);
      padding: 0 var(--page-pad);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      transition: background 2.2s ease, border-color 2.2s ease;
    }
    .po-brand {
      font-family: var(--poetry-classical);
      font-size: 22px;
      font-weight: 500;
      font-style: italic;
      color: var(--po-text);
      text-decoration: none;
      letter-spacing: -0.01em;
      transition: color 2.2s ease;
    }
    .po-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .po-nav-links a {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: color-mix(in srgb, var(--po-text) 45%, transparent);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .po-nav-links a:hover { color: var(--po-accent); }
    .po-nav-links a.is-current { color: var(--po-text); }

    /* ── Article ── */
    /* Width is sized to fit the longest line of the poem (~74 chars) on one
       row at the body font-size below. This is a deliberate fixed-line-length
       layout: every docx line break renders as a hard break and the browser
       never adds its own mid-line wraps on desktop. Narrow viewports fall
       back to pre-wrap word-wrap (see @media block). */
    .po-article {
      max-width: 880px;
      margin: 0 auto;
      padding: 96px var(--page-pad) 120px;
      position: relative;
      z-index: 5;
    }

    /* ── Masthead ── */
    .po-masthead { margin-bottom: 56px; }
    .po-back {
      display: inline-block;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: color-mix(in srgb, var(--po-text) 48%, transparent);
      text-decoration: none;
      margin-bottom: 56px;
      transition: color 0.3s ease;
    }
    .po-back:hover { color: var(--po-accent); }
    .po-year {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--po-accent);
      margin: 0 0 22px;
      transition: color 2.2s ease;
    }
    .po-title {
      font-family: var(--poetry-classical);
      font-size: clamp(46px, 7.5vw, 76px);
      font-weight: 500;
      letter-spacing: -0.015em;
      line-height: 1.04;
      color: var(--po-text);
      margin: 0;
      transition: color 2.2s ease;
    }

    /* ── Body ── */
    .po-body {
      font-family: var(--poetry-classical);
      /* Sized so the longest line of the poem (~74 chars) fits in the
         880px article column without browser-wrapping mid-line. */
      font-size: clamp(18px, 1.8vw, 21px);
      line-height: 1.7;
      color: var(--po-text);
      transition: color 2.2s ease;
    }
    .po-section {
      margin-top: 64px;
    }
    .po-section:first-child { margin-top: 0; }
    .po-section-head {
      margin: 0 0 36px;
      font-weight: 400;
    }
    .po-numeral {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.2em;
      color: var(--po-accent);
      text-transform: uppercase;
      transition: color 2.2s ease;
    }
    .po-stanza {
      white-space: pre-wrap;
      margin: 0 0 28px;
      font-family: inherit;
    }
    .po-stanza:last-child { margin-bottom: 0; }

    /* ── Footer ── */
    .po-footer {
      margin-top: 128px;
      padding-top: 40px;
      border-top: 1px solid color-mix(in srgb, var(--po-text) 14%, transparent);
      transition: border-color 2.2s ease;
    }
    .po-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 10px;
      color: var(--po-text);
      transition: color 0.3s ease;
    }
    .po-next-label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--po-accent);
      transition: color 2.2s ease;
    }
    .po-next-title {
      font-family: var(--poetry-classical);
      font-style: italic;
      font-weight: 500;
      font-size: clamp(22px, 3vw, 28px);
      line-height: 1.2;
      color: var(--po-text);
      transition: color 2.2s ease;
    }
    .po-next:hover .po-next-title { color: var(--po-accent); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .po-article { padding: 108px var(--page-pad) 120px; }
      .po-masthead { margin-bottom: 64px; }
      .po-back { margin-bottom: 40px; }
      .po-body { font-size: 17.5px; line-height: 1.7; }
      .po-section { margin-top: 64px; }
      .po-footer { margin-top: 88px; }
      .po-lamp { right: 10px; bottom: 10px; width: 88px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .po-page,
      .po-nav,
      .po-title,
      .po-year,
      .po-body,
      .po-numeral,
      .po-next-label,
      .po-next-title,
      .po-brand,
      .po-footer,
      .po-lamp-cast,
      .po-scanlines { transition: none; }
      .po-smoke-wisp,
      .po-ghost,
      .po-scanlines { animation: none; }
      .po-ghost { opacity: 0.12; }
      .po-scanlines { opacity: 0; }
      .po-page[data-stage="III"] .po-scanlines { opacity: 0.35; }
    }
  </style>

  <script>
    const page = document.querySelector<HTMLElement>('.po-page');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── Stage progression — most-in-view section drives page temperature ──
    const sections = document.querySelectorAll<HTMLElement>('.po-section');
    if (page && sections.length && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        let best: IntersectionObserverEntry | undefined;
        for (const e of entries) {
          if (!best || e.intersectionRatio > best.intersectionRatio) best = e;
        }
        if (best && best.isIntersecting) {
          const stage = (best.target as HTMLElement).dataset.stage;
          if (stage) page.setAttribute('data-stage', stage);
        }
      }, { threshold: [0.2, 0.4, 0.6, 0.8], rootMargin: '-15% 0px -35% 0px' });
      sections.forEach((s) => io.observe(s));
    }

    // ── Metaball lava lamp ──
    // Soft radial blobs drawn to a small internal canvas; the wrapper's
    // blur+contrast filter turns overlapping soft blobs into sharp-edged
    // liquid-merging shapes. Scroll velocity bumps blob motion.
    const canvas = document.querySelector<HTMLCanvasElement>('.po-lamp-canvas');
    if (canvas && !reduce) {
      const ctx = canvas.getContext('2d');
      if (ctx) {
        // Polygon vertex count per blob. Each vertex's distance from
        // center is driven by a sum of low-frequency sines, per-vertex
        // seeded, producing continuous organic boundary morphing.
        const VERTS = 22;

        type Blob = {
          x: number; y: number;
          vx: number;
          baseR: number;    // unscaled radius
          temp: number;     // 0..1 — controls rise/fall via ease
          phase: number;    // master time accumulator for the wobble
          vertPhase: Float32Array; // per-vertex phase offsets
        };
        type Reservoir = {
          x: number; y: number;
          baseR: number;
          phase: number;
        };
        const blobs: Blob[] = [];
        let reservoir: Reservoir | null = null;
        const BLOB_COUNT = 5;
        let W = 0, H = 0;
        let scrollBoost = 0;    // 0..1 multiplier on blob speed
        let lastScrollY = 0;

        const resize = () => {
          const rect = canvas.getBoundingClientRect();
          const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
          W = Math.max(1, Math.floor(rect.width * dpr));
          H = Math.max(1, Math.floor(rect.height * dpr));
          canvas.width = W;
          canvas.height = H;
          if (blobs.length === 0) {
            // Persistent bottom reservoir — the cooled wax pool.
            reservoir = {
              x: W / 2,
              y: H - W * 0.18,
              baseR: W * 0.55,
              phase: 0,
            };
            for (let i = 0; i < BLOB_COUNT; i++) {
              // Staggered initial temperatures so blobs are out of sync —
              // some already rising, some already falling, some near the
              // reservoir reheating. This is what makes a real lamp asymmetric.
              const initTemp = (i / BLOB_COUNT) + Math.random() * 0.12;
              const initY = H - W * 0.25 - Math.random() * H * 0.55;
              const vertPhase = new Float32Array(VERTS);
              for (let v = 0; v < VERTS; v++) {
                vertPhase[v] = Math.random() * Math.PI * 2;
              }
              blobs.push({
                x: W * (0.35 + Math.random() * 0.30),
                y: initY,
                vx: (Math.random() - 0.5) * 0.18,
                baseR: W * (0.20 + Math.random() * 0.08),
                temp: Math.min(1, Math.max(0, initTemp)),
                phase: Math.random() * Math.PI * 2,
                vertPhase,
              });
            }
          } else if (reservoir) {
            reservoir.x = W / 2;
            reservoir.y = H - W * 0.18;
            reservoir.baseR = W * 0.55;
          }
        };
        resize();
        window.addEventListener('resize', resize);

        let running = true;
        let rafId: number | null = null;
        let last = performance.now();

        // Smoothstep ease for gentler acceleration at rise/fall extremes.
        const ease = (t: number) => t * t * (3 - 2 * t);

        // Paints a soft circular gradient at (x, y, r) — used for the
        // reservoir pool only.
        const paintBlob = (x: number, y: number, r: number) => {
          const g = ctx.createRadialGradient(x, y, 0, x, y, r);
          g.addColorStop(0,    'rgba(255, 180, 100, 1)');
          g.addColorStop(0.55, 'rgba(255, 100, 40, 0.65)');
          g.addColorStop(1,    'rgba(200, 60, 20, 0)');
          ctx.fillStyle = g;
          ctx.beginPath();
          ctx.arc(x, y, r, 0, Math.PI * 2);
          ctx.fill();
        };

        // Paints a blob as a polygon with per-vertex wobble — smooth
        // organic boundary, no orbital substructure. Three slow sines
        // at different frequencies per vertex produce plasmic deformation
        // that doesn't visibly repeat.
        const paintGlobule = (b: Blob, yStretch: number) => {
          const cx = b.x;
          const cy = b.y;
          const t = b.phase;
          // Build vertex list first
          const xs = new Array<number>(VERTS);
          const ys = new Array<number>(VERTS);
          let maxR = 0;
          for (let i = 0; i < VERTS; i++) {
            const theta = (i / VERTS) * Math.PI * 2;
            const ph = b.vertPhase[i];
            const wobble =
              0.16 * Math.sin(t * 0.32 + ph) +
              0.11 * Math.sin(t * 0.71 + ph * 1.7) +
              0.06 * Math.sin(t * 1.13 + ph * 2.4);
            const r = b.baseR * (1 + wobble);
            const dx = Math.cos(theta) * r;
            const dy = Math.sin(theta) * r * yStretch;
            xs[i] = cx + dx;
            ys[i] = cy + dy;
            const d = Math.hypot(dx, dy);
            if (d > maxR) maxR = d;
          }

          // Fill with a radial gradient sized to the widest vertex so the
          // center stays bright and edges fall off softly for the filter
          // to turn into clean metaball merges.
          const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxR * 1.05);
          g.addColorStop(0,    'rgba(255, 180, 100, 1)');
          g.addColorStop(0.55, 'rgba(255, 100, 40, 0.65)');
          g.addColorStop(1,    'rgba(200, 60, 20, 0)');
          ctx.fillStyle = g;

          // Smooth closed curve through midpoints using each vertex as a
          // quadratic control point — rounder than straight-line polygon,
          // reads as fluid rather than faceted.
          ctx.beginPath();
          const mx0 = (xs[VERTS - 1] + xs[0]) * 0.5;
          const my0 = (ys[VERTS - 1] + ys[0]) * 0.5;
          ctx.moveTo(mx0, my0);
          for (let i = 0; i < VERTS; i++) {
            const next = (i + 1) % VERTS;
            const mx = (xs[i] + xs[next]) * 0.5;
            const my = (ys[i] + ys[next]) * 0.5;
            ctx.quadraticCurveTo(xs[i], ys[i], mx, my);
          }
          ctx.closePath();
          ctx.fill();
        };

        const step = (now: number) => {
          rafId = null;
          if (!running) return;
          const dt = Math.min(48, now - last);
          last = now;

          ctx.clearRect(0, 0, W, H);

          const speedMul = 1 + scrollBoost * 2.4;
          scrollBoost *= 0.94;

          // ── Reservoir: stationary pool at the bottom, gently breathing ──
          if (reservoir) {
            reservoir.phase += dt * 0.0006;
            const rR = reservoir.baseR * (1 + 0.06 * Math.sin(reservoir.phase));
            paintBlob(reservoir.x, reservoir.y, rR);
          }

          // ── Mutual weak repulsion ─────────────────────────────────────
          // Keeps blobs from sticking; they pass through each other but
          // don't permanently overlap. Visually the filter still merges
          // them when they pass, then separates them out.
          for (let i = 0; i < blobs.length; i++) {
            for (let j = i + 1; j < blobs.length; j++) {
              const a = blobs[i];
              const b = blobs[j];
              const dx = b.x - a.x;
              const dy = b.y - a.y;
              const distSq = dx * dx + dy * dy;
              const minDist = (a.baseR + b.baseR) * 1.3;
              if (distSq < minDist * minDist && distSq > 1) {
                const dist = Math.sqrt(distSq);
                const push = (minDist - dist) * 0.0012 * dt;
                const nx = dx / dist;
                const ny = dy / dist;
                a.x -= nx * push;
                a.y -= ny * push;
                b.x += nx * push;
                b.y += ny * push;
              }
            }
          }

          // ── Per-blob temperature dynamics + rendering ─────────────────
          for (const b of blobs) {
            b.phase += dt * 0.0004;

            // Temperature: rises when near the reservoir (reheating), cools
            // as the blob climbs away from it. Normalized rise fraction
            // drives cooling rate — higher blobs cool faster.
            const distFromBottom = Math.max(0, H - b.y);
            const heightFraction = Math.min(1, distFromBottom / (H * 0.82));
            const nearReservoir = reservoir
              ? Math.hypot(b.x - reservoir.x, b.y - reservoir.y) < reservoir.baseR * 1.15
              : false;

            if (nearReservoir) {
              b.temp = Math.min(1, b.temp + dt * 0.0008);
            } else {
              b.temp = Math.max(0, b.temp - dt * 0.00022 * (0.4 + heightFraction));
            }

            // Velocity from temperature: ease(temp) controls rise, ease(1-temp) controls fall.
            const riseSpeed = 0.32;
            const fallSpeed = 0.42;
            const vy = -riseSpeed * ease(b.temp) + fallSpeed * ease(1 - b.temp);

            // Bulb-shape-aware horizontal centering — stronger at top/bottom
            // where the bulb narrows.
            const cx = W / 2;
            const pinchFactor = 1 + Math.abs(b.y - H / 2) / (H / 2) * 1.6;
            const baseCentering = 0.0014;
            b.x += (cx - b.x) * baseCentering * pinchFactor * dt;

            // Lateral drift
            b.x += (Math.sin(b.phase * 2.2) * 0.08 + b.vx) * (dt / 16) * speedMul;
            b.y += vy * (dt / 16) * speedMul;

            // Soft clamp to canvas so blobs never leave the bulb (backup to
            // the filter clip; also stops drift at edges when temp is low).
            const margin = b.baseR * 0.4;
            if (b.y < margin) { b.y = margin; b.temp = Math.max(0, b.temp - 0.02); }
            if (b.y > H - margin) b.y = H - margin;

            // Velocity-based vertical stretch — faster-moving blobs
            // elongate along their direction of travel, like wax pulled
            // by the density gradient in the surrounding fluid.
            const vMag = Math.min(1, Math.abs(vy) / 0.35);
            const yStretch = 1 + vMag * 0.28;

            paintGlobule(b, yStretch);
          }

          rafId = requestAnimationFrame(step);
        };
        rafId = requestAnimationFrame(step);

        // Scroll velocity → temporary speed boost
        const onScroll = () => {
          const delta = Math.abs(window.scrollY - lastScrollY);
          lastScrollY = window.scrollY;
          scrollBoost = Math.min(1, scrollBoost + delta / 800);
        };
        window.addEventListener('scroll', onScroll, { passive: true });

        const pause = () => {
          running = false;
          if (rafId !== null) cancelAnimationFrame(rafId);
          rafId = null;
        };
        const resume = () => {
          if (running) return;
          running = true;
          last = performance.now();
          rafId = requestAnimationFrame(step);
        };
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'hidden') pause();
          else resume();
        });
        document.addEventListener('astro:before-swap', pause);
      }
    }
  </script>
</PoetryLayout>
