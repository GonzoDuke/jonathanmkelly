---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parseKerouac } from '../data/poems/kerouac-is-chilling-on-my-couch.js';

const sections = parseKerouac();
const year = '2024';
const next = { slug: 'potheads-dont-believe-in-time', title: 'Potheads Don\u2019t Believe in Time' };
---
<PoetryLayout
  title="Kerouac is Chilling on My Couch — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/kerouac-is-chilling-on-my-couch"
>
  <div class="kc-page" data-stage="1">
    <!-- Fixed room scene behind all content: floor line across the viewport,
         couch with reclining Jack on it, dozing and smoking throughout. -->
    <div class="kc-room" aria-hidden="true">
      <svg
        class="kc-room-svg"
        viewBox="0 0 1200 720"
        preserveAspectRatio="xMidYMax slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <defs>
          <linearGradient id="kc-floor-grad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="rgba(60, 36, 16, 0.85)" />
            <stop offset="55%"  stop-color="rgba(30, 18, 8, 0.75)" />
            <stop offset="100%" stop-color="rgba(8, 4, 2, 0.85)" />
          </linearGradient>
          <radialGradient id="kc-ember" cx="50%" cy="50%" r="50%">
            <stop offset="0%"  stop-color="#FFC890" stop-opacity="0.98" />
            <stop offset="40%" stop-color="#FF8838" stop-opacity="0.75" />
            <stop offset="100%" stop-color="#C03810" stop-opacity="0" />
          </radialGradient>
        </defs>

        <!-- floor spans the viewport -->
        <rect x="0" y="448" width="1200" height="272" fill="url(#kc-floor-grad)" />
        <line x1="0" y1="448" x2="1200" y2="448"
              stroke="#6B4024" stroke-width="1.4" opacity="0.65" />
        <g stroke="#0E0604" stroke-width="1" opacity="0.5">
          <line x1="0" y1="500" x2="1200" y2="508" />
          <line x1="0" y1="568" x2="1200" y2="580" />
          <line x1="0" y1="644" x2="1200" y2="660" />
        </g>

        <!-- floor shadow under the couch -->
        <ellipse cx="720" cy="612" rx="310" ry="11" fill="#000" opacity="0.42" />

        <!-- ─── Couch ─── -->
        <g class="kc-couch">
          <rect x="440" y="528" width="560" height="78" rx="12" fill="#1A0F08" />
          <rect x="464" y="430" width="516" height="106" rx="14" fill="#1E1108" />
          <rect x="468" y="432" width="510" height="4" rx="2" fill="#3A2410" opacity="0.7" />
          <rect x="424" y="452" width="44" height="158" rx="12" fill="#25160B" />
          <rect x="976" y="452" width="44" height="158" rx="12" fill="#25160B" />
          <rect x="1016" y="454" width="4" height="154" rx="2" fill="#5A3818" opacity="0.8" />
          <line x1="630" y1="440" x2="630" y2="528"
                stroke="#361D0E" stroke-width="1.4" opacity="0.7" />
          <line x1="810" y1="440" x2="810" y2="528"
                stroke="#361D0E" stroke-width="1.4" opacity="0.7" />
        </g>

        <!-- ─── Empty couch — Jack is present in the poem, absent from the image.
             The evidence of his presence sits on the end table: ashtray with
             a smoldering cigarette, coffee mug, open book, vinyl sleeve on
             the floor. ─── -->

        <!-- End table to the left of the couch, on the floor -->
        <g class="kc-table">
          <!-- floor shadow beneath the table -->
          <ellipse cx="354" cy="598" rx="96" ry="5" fill="#000" opacity="0.42" />
          <!-- table body -->
          <rect x="280" y="474" width="148" height="124" rx="4" fill="#1A0F08" />
          <!-- tabletop (thin lighter stripe catches lamp) -->
          <rect x="274" y="470" width="160" height="8" rx="2" fill="#2C1A0C" />
          <rect x="274" y="470" width="160" height="2" rx="1" fill="#4A2E18" opacity="0.8" />
          <!-- drawer line + pull -->
          <line x1="292" y1="516" x2="416" y2="516" stroke="#0A0604" stroke-width="1" opacity="0.7" />
          <rect x="342" y="527" width="24" height="3" rx="1" fill="#3A2410" opacity="0.85" />
        </g>

        <!-- Vinyl sleeve leaning against the table leg -->
        <g class="kc-vinyl" transform="rotate(-12 252 560)">
          <rect x="218" y="524" width="68" height="76" rx="1" fill="#120806" />
          <rect x="218" y="524" width="68" height="76" rx="1" fill="none"
                stroke="#2C1A0C" stroke-width="0.8" />
          <!-- sleeve label block -->
          <rect x="234" y="548" width="36" height="22" rx="0.5" fill="#2A1810" opacity="0.85" />
          <!-- vinyl record edge poking out top of sleeve -->
          <ellipse cx="252" cy="524" rx="24" ry="3.5" fill="#050201" opacity="0.9" />
        </g>

        <!-- Open book, lying flat on the table -->
        <g class="kc-book">
          <!-- pages base -->
          <rect x="296" y="462" width="62" height="10" rx="1" fill="#4A2F14" />
          <!-- spine shadow -->
          <line x1="327" y1="462" x2="327" y2="472" stroke="#1A0F08" stroke-width="1" />
          <!-- page texture strokes -->
          <line x1="302" y1="467" x2="322" y2="467" stroke="#35200C" stroke-width="0.6" opacity="0.75" />
          <line x1="332" y1="467" x2="352" y2="467" stroke="#35200C" stroke-width="0.6" opacity="0.75" />
        </g>

        <!-- Coffee mug with a thin steam curl -->
        <g class="kc-mug">
          <!-- body -->
          <rect x="382" y="445" width="24" height="28" rx="2.5" fill="#180D06" />
          <rect x="382" y="445" width="24" height="2.4" rx="1.2" fill="#3A2410" opacity="0.85" />
          <!-- handle arc -->
          <path d="M 406 452 Q 416 456 416 462 Q 416 468 406 472"
                stroke="#180D06" stroke-width="3" fill="none" stroke-linecap="round" />
          <!-- steam -->
          <path class="kc-steam" d="M 390 440 Q 388 434 390 428 Q 392 424 390 420"
                stroke="#F4EBD4" stroke-width="1" fill="none" opacity="0.32"
                stroke-linecap="round" />
          <path class="kc-steam kc-steam-b" d="M 398 442 Q 400 436 398 430 Q 396 426 398 422"
                stroke="#F4EBD4" stroke-width="1" fill="none" opacity="0.28"
                stroke-linecap="round" />
        </g>

        <!-- Ashtray with a smoldering cigarette -->
        <g class="kc-ashtray">
          <ellipse cx="354" cy="470" rx="30" ry="7.5" fill="#050201" />
          <ellipse cx="354" cy="468" rx="30" ry="7.5" fill="none"
                   stroke="#2A1810" stroke-width="1.2" />
          <ellipse cx="354" cy="469" rx="24" ry="5" fill="#000" opacity="0.75" />
        </g>

        <!-- Cigarette balanced across the ashtray -->
        <rect x="322" y="461" width="38" height="3.2" rx="1.4" fill="#E4D3A4"
              transform="rotate(-10 341 462.6)" />
        <!-- filter end -->
        <rect x="354" y="462.8" width="7" height="3" rx="0.8" fill="#B89060"
              transform="rotate(-10 357 464.3)" />

        <!-- ember glow + hot core -->
        <circle cx="320" cy="465" r="15" fill="url(#kc-ember)" />
        <circle cx="320" cy="465" r="2" fill="#FFD099" />
      </svg>

      <!-- Smoke rises in viewport coordinates, aligned to the ember at ~(43.3%, 89.4%) of the SVG -->
      <div class="kc-room-smoke">
        <span class="kc-puff" style="--d: 0s"></span>
        <span class="kc-puff" style="--d: 1.1s"></span>
        <span class="kc-puff" style="--d: 2.2s"></span>
        <span class="kc-puff" style="--d: 3.3s"></span>
        <span class="kc-puff" style="--d: 4.4s"></span>
        <span class="kc-puff" style="--d: 5.5s"></span>
      </div>
    </div>

    <nav class="kc-nav">
      <a href="/" class="kc-brand">JMK</a>
      <div class="kc-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="kc-article">
      <header class="kc-masthead">
        <a href="/poetry" class="kc-back">&larr; Poetry</a>
        <p class="kc-year">{year}</p>
        <h1 class="kc-title">Kerouac is Chilling on My Couch</h1>
      </header>

      <div class="kc-body">
        {sections.map((section, idx) => (
          <section class="kc-section" data-stage={idx + 1}>
            <h2 class="kc-section-head" aria-label={`Section ${section.numeral}`}>
              <span class="kc-numeral">{section.numeral}.</span>
            </h2>
            {section.stanzas.map((stanza) => (
              <p class="kc-stanza">{stanza.map((line, li) => (
                <Fragment>
                  {line}
                  {li < stanza.length - 1 && '\n'}
                </Fragment>
              ))}</p>
            ))}
          </section>
        ))}
      </div>

      <footer class="kc-footer">
        <a href={`/${next.slug}`} class="kc-next">
          <span class="kc-next-label">Next poem &rarr;</span>
          <span class="kc-next-title">{next.title}</span>
        </a>
      </footer>
    </article>
  </div>

  <style is:global>
    .kc-page {
      --kc-text: #F4EBD4;
      --kc-muted: rgba(244, 235, 212, 0.55);
      --kc-amber: #D4A574;
      --kc-amber-bright: #FFCC88;
      --kc-bg: #36251A;
      --kc-lamp: 0.35;
      color: var(--kc-text);
      min-height: 100vh;
      position: relative;
      font-family: var(--serif);
      overflow-x: hidden;
      background: var(--kc-bg);
      transition: background-color 1.4s ease, --kc-lamp 1.4s ease;
    }
    /* Stage-driven palette + lamp intensity. IntersectionObserver sets
       [data-stage] on the root to whichever section the reader is in. */
    .kc-page[data-stage="1"] { --kc-bg: #36251A; --kc-lamp: 0.42; }
    .kc-page[data-stage="2"] { --kc-bg: #2B1E13; --kc-lamp: 0.32; }
    .kc-page[data-stage="3"] { --kc-bg: #24190F; --kc-lamp: 0.22; }
    .kc-page[data-stage="4"] { --kc-bg: #1C140D; --kc-lamp: 0.13; }

    /* Lamplight from upper-right, its intensity tied to --kc-lamp */
    .kc-page::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background:
        radial-gradient(ellipse 70vw 60vh at 90% 8%,
          rgba(255, 204, 136, calc(var(--kc-lamp) * 0.9)) 0%,
          rgba(212, 165, 116, calc(var(--kc-lamp) * 0.45)) 24%,
          rgba(74, 46, 28, calc(var(--kc-lamp) * 0.2)) 50%,
          transparent 75%);
      transition: background 1.4s ease;
    }

    /* ── Fixed room scene behind all content ── */
    .kc-room {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      overflow: hidden;
    }
    .kc-room-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    /* Slow breath on the coffee-cup steam */
    .kc-steam {
      transform-origin: center;
      transform-box: fill-box;
      animation: kc-steam-sway 4.2s ease-in-out infinite;
    }
    .kc-steam-b { animation-delay: 2.1s; }
    @keyframes kc-steam-sway {
      0%, 100% { opacity: 0.32; transform: translateY(0) scaleX(1); }
      50%      { opacity: 0.1;  transform: translateY(-3px) scaleX(1.1); }
    }

    /* Smoke rising from the ashtray ember.
       Ember sits at SVG (320, 465). SVG uses preserveAspectRatio
       "xMidYMax slice" → ember is 280 units left of center-x (600), and
       720 − 465 = 255 units up from bottom. Scale factor varies with
       viewport; max(vw/1200, vh/720) covers both cases. */
    .kc-room-smoke {
      position: fixed;
      left: calc(50% - max(23.3vw, 38.9vh));
      bottom: max(21.3vw, 35.4vh);
      width: 48px;
      height: 40vh;
      pointer-events: none;
      z-index: 2;
      transform: translateX(-50%);
    }
    .kc-puff {
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: radial-gradient(circle,
        rgba(244, 235, 212, 0.7) 0%,
        rgba(244, 235, 212, 0.25) 45%,
        rgba(244, 235, 212, 0) 100%);
      transform: translate(-50%, 0) scale(0.5);
      opacity: 0;
      animation: kc-smoke-rise 7.5s ease-out infinite;
      animation-delay: var(--d, 0s);
      will-change: transform, opacity;
      filter: blur(1.6px);
    }
    @keyframes kc-smoke-rise {
      0%   { transform: translate(-50%, 0) scale(0.5); opacity: 0; }
      10%  { transform: translate(calc(-50% + 6px), -30px) scale(0.9);
             opacity: 0.55; }
      32%  { transform: translate(calc(-50% + 20px), -100px) scale(1.6);
             opacity: 0.48; }
      60%  { transform: translate(calc(-50% - 8px), -200px) scale(2.4);
             opacity: 0.3; }
      100% { transform: translate(calc(-50% + 14px), -320px) scale(3.4);
             opacity: 0; }
    }

    /* Soft top-of-scene fade so text reads cleanly above the horizon line */
    .kc-room::after {
      content: "";
      position: absolute;
      left: 0; right: 0; top: 0;
      height: 50vh;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        var(--kc-bg) 0%,
        var(--kc-bg) 40%,
        rgba(28, 20, 13, 0) 100%);
      transition: background 1.4s ease;
    }

    /* ── Nav ── */
    .kc-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(22, 15, 10, 0.78);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(244, 235, 212, 0.08);
      padding: 0 var(--page-pad);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .kc-brand {
      font-family: var(--serif);
      font-style: italic;
      font-size: 20px;
      font-weight: 500;
      color: var(--kc-text);
      text-decoration: none;
      letter-spacing: -0.005em;
    }
    .kc-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .kc-nav-links a {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: rgba(244, 235, 212, 0.42);
      text-decoration: none;
      transition: color 0.3s ease;
    }
    .kc-nav-links a:hover { color: var(--kc-amber); }
    .kc-nav-links a.is-current { color: rgba(244, 235, 212, 0.82); }

    /* ── Article ── */
    .kc-article {
      max-width: 620px;
      margin: 0 auto;
      padding: 120px var(--page-pad) 160px;
      position: relative;
      z-index: 5;
    }

    /* ── Masthead ── */
    .kc-masthead { margin-bottom: 96px; }
    .kc-back {
      display: inline-block;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(244, 235, 212, 0.45);
      text-decoration: none;
      margin-bottom: 56px;
      transition: color 0.3s ease;
    }
    .kc-back:hover { color: var(--kc-amber); }
    .kc-year {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--kc-amber);
      margin: 0 0 22px;
    }
    .kc-title {
      font-family: var(--poetry-italic-display);
      font-style: italic;
      font-size: clamp(42px, 7vw, 70px);
      font-weight: 500;
      letter-spacing: -0.015em;
      line-height: 1.02;
      color: var(--kc-text);
      margin: 0;
    }

    /* ── Body ── */
    .kc-body {
      font-family: var(--serif);
      font-size: 21px;
      line-height: 1.75;
      color: var(--kc-text);
      /* Text-shadow ensures legibility when text passes over the couch/floor
         silhouettes in the fixed scene behind it. */
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.85),
                   0 0 10px rgba(0, 0, 0, 0.55);
    }
    .kc-title {
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.75),
                   0 0 18px rgba(0, 0, 0, 0.35);
    }
    .kc-masthead .kc-year,
    .kc-masthead .kc-back,
    .kc-footer .kc-next-label,
    .kc-footer .kc-next-title {
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
    }
    .kc-section {
      margin-top: 72px;
      padding-top: 8px;
    }
    .kc-section:first-child { margin-top: 0; }
    .kc-section-head {
      margin: 0 0 36px;
      font-weight: 400;
    }
    .kc-numeral {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.2em;
      color: var(--kc-amber);
      text-transform: uppercase;
    }
    .kc-stanza {
      white-space: pre-wrap;
      margin: 0 0 32px;
      font-family: var(--serif);
    }
    .kc-stanza:last-child { margin-bottom: 0; }

    /* ── Footer ── */
    .kc-footer {
      margin-top: 128px;
      padding-top: 40px;
      border-top: 1px solid rgba(244, 235, 212, 0.12);
    }
    .kc-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 10px;
      color: var(--kc-text);
      transition: color 0.3s ease;
    }
    .kc-next-label {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--kc-amber);
    }
    .kc-next-title {
      font-family: var(--poetry-classical);
      font-style: italic;
      font-weight: 500;
      font-size: clamp(22px, 3vw, 28px);
      line-height: 1.2;
      color: var(--kc-text);
    }
    .kc-next:hover .kc-next-title { color: var(--kc-amber); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .kc-article { padding: 108px var(--page-pad) 120px; }
      .kc-masthead { margin-bottom: 56px; }
      .kc-back { margin-bottom: 40px; }
      .kc-body { font-size: 19px; line-height: 1.72; }
      .kc-section { margin-top: 56px; }
      .kc-footer { margin-top: 96px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .kc-page { transition: none; }
      .kc-puff { animation: none; opacity: 0; }
      .kc-steam { animation: none; }
    }
  </style>

  <script>
    const page = document.querySelector<HTMLElement>('.kc-page');

    // ── Stage progression: deepening night via data-stage ──
    const sections = document.querySelectorAll<HTMLElement>('.kc-section');
    if (page && sections.length && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        // find the most-in-view section and use it as the current stage
        let best: IntersectionObserverEntry | undefined;
        for (const e of entries) {
          if (!best || e.intersectionRatio > best.intersectionRatio) best = e;
        }
        if (best && best.isIntersecting) {
          const stage = (best.target as HTMLElement).dataset.stage;
          if (stage) page.setAttribute('data-stage', stage);
        }
      }, { threshold: [0.25, 0.5, 0.75], rootMargin: '-20% 0px -40% 0px' });
      sections.forEach((s) => io.observe(s));
    }
  </script>
</PoetryLayout>
