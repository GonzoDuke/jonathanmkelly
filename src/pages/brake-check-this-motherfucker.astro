---
import PoetryLayout from '../layouts/PoetryLayout.astro';
import { parseBrakeCheck } from '../data/poems/brake-check-this-motherfucker.js';

const stanzas = parseBrakeCheck();
const year = '2025';
const next = { slug: 'to-become-what-burns', title: 'To Become What Burns' };
---
<PoetryLayout
  title="Brake Check This, Motherfucker — Jonathan M. Kelly"
  description="A poem by Jonathan M. Kelly."
  ogUrl="https://www.jonathanmkelly.com/brake-check-this-motherfucker"
>
  <div class="bc-page">
    <div class="bc-scanlines" aria-hidden="true"></div>

    <nav class="bc-nav">
      <a href="/" class="bc-brand">JMK</a>
      <div class="bc-nav-links">
        <a href="/projects">Projects</a>
        <a href="/detourist">detourist</a>
        <a href="/poetry" class="is-current">Poetry</a>
        <a href="/agency-artifact">A&amp;A</a>
        <a href="mailto:contact@jonathanmkelly.com">Contact</a>
        <a href="/about">About</a>
      </div>
    </nav>

    <article class="bc-article">
      <header class="bc-masthead">
        <a href="/poetry" class="bc-back">&larr; Poetry</a>
        <p class="bc-year">{year}</p>
        <h1 class="bc-title">
          <span class="bc-title-layer bc-title-red" aria-hidden="true">Brake Check This, Motherfucker</span>
          <span class="bc-title-layer bc-title-cyan" aria-hidden="true">Brake Check This, Motherfucker</span>
          <span class="bc-title-text">Brake Check This, Motherfucker</span>
        </h1>
      </header>

      <div class="bc-body">
        {stanzas.map((stanza) => {
          const cls = stanza.role === 'callout' ? 'bc-stanza bc-callout' : 'bc-stanza';
          const dataTrigger = stanza.role === 'desaturate' || stanza.role === 'resaturate'
            ? stanza.role
            : undefined;
          return (
            <p class={cls} data-trigger={dataTrigger}>
              {stanza.lines.map((line, i) => (
                <Fragment>
                  {line}
                  {i < stanza.lines.length - 1 && <br />}
                </Fragment>
              ))}
            </p>
          );
        })}
      </div>

      <footer class="bc-footer">
        <a href={`/${next.slug}`} class="bc-next">
          <span class="bc-next-label">Next poem &rarr;</span>
          <span class="bc-next-title">{next.title}</span>
        </a>
      </footer>
    </article>

  </div>

  <style is:global>
    .bc-page {
      --bc-bg: #1a0604;
      --bc-bg-deep: #0a0302;
      --bc-red: #ff3c28;
      --bc-cyan: #30d9ff;
      --bc-text: #FFE4D6;
      --bc-amber: #ffb89a;
      background: radial-gradient(ellipse at 50% 30%, #240a06 0%, var(--bc-bg) 55%, var(--bc-bg-deep) 100%);
      color: var(--bc-text);
      min-height: 100vh;
      position: relative;
      font-family: var(--poetry-mono);
      overflow-x: hidden;
      transition: filter 1.6s ease;
    }
    .bc-page.is-calm {
      filter: saturate(0.25) brightness(0.92);
    }

    /* ── Scanlines overlay ── */
    .bc-scanlines {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      background: repeating-linear-gradient(
        to bottom,
        transparent 0,
        transparent 2px,
        rgba(255, 60, 40, 0.045) 2.5px,
        rgba(255, 60, 40, 0.015) 3px,
        transparent 3.5px
      );
      mix-blend-mode: screen;
      transition: opacity 1.4s ease;
    }
    .bc-page.is-calm .bc-scanlines { opacity: 0.22; }

    /* ── Nav ── */
    .bc-nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(12, 4, 3, 0.85);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(255, 60, 40, 0.1);
      padding: 0 var(--page-pad);
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .bc-brand {
      font-family: var(--poetry-display-condensed);
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: var(--bc-text);
      text-decoration: none;
      text-transform: uppercase;
    }
    .bc-nav-links {
      display: flex;
      gap: clamp(20px, 3vw, 36px);
      align-items: center;
      flex-wrap: wrap;
    }
    .bc-nav-links a {
      font-family: var(--poetry-mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(255, 228, 214, 0.4);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    .bc-nav-links a:hover { color: var(--bc-red); }
    .bc-nav-links a.is-current { color: var(--bc-text); }

    /* ── Article ── */
    .bc-article {
      max-width: 720px;
      margin: 0 auto;
      padding: 120px var(--page-pad) 160px;
      position: relative;
      z-index: 5;
    }

    /* ── Masthead ── */
    .bc-masthead { margin-bottom: 72px; }
    .bc-back {
      display: inline-block;
      font-family: var(--poetry-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(255, 228, 214, 0.5);
      text-decoration: none;
      margin-bottom: 56px;
      transition: color 0.2s ease;
    }
    .bc-back:hover { color: var(--bc-red); }
    .bc-year {
      font-family: var(--poetry-mono);
      font-size: 11px;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--bc-red);
      margin: 0 0 22px;
    }
    .bc-title {
      position: relative;
      font-family: var(--poetry-display-condensed);
      font-size: clamp(54px, 9vw, 104px);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: -0.005em;
      line-height: 0.92;
      color: var(--bc-text);
      margin: 0;
      isolation: isolate;
    }
    .bc-title-text {
      position: relative;
      z-index: 3;
      display: block;
    }
    .bc-title-layer {
      position: absolute;
      top: 0; left: 0;
      width: 100%;
      display: block;
      pointer-events: none;
      opacity: 0;
      mix-blend-mode: screen;
      will-change: transform, opacity;
    }
    .bc-title-red  { color: var(--bc-red); z-index: 2; }
    .bc-title-cyan { color: var(--bc-cyan); z-index: 1; }
    .bc-title.is-glitching .bc-title-red  { animation: bc-glitch-red  0.42s steps(5, end); }
    .bc-title.is-glitching .bc-title-cyan { animation: bc-glitch-cyan 0.42s steps(5, end); }
    .bc-title.is-glitching .bc-title-text { animation: bc-glitch-shake 0.42s steps(5, end); }
    @keyframes bc-glitch-red {
      0%   { opacity: 0;    transform: translate(0, 0); }
      25%  { opacity: 0.85; transform: translate(-3px, -1px); }
      50%  { opacity: 0.9;  transform: translate(-4px, 1px); }
      75%  { opacity: 0.7;  transform: translate(-2px, 0); }
      100% { opacity: 0;    transform: translate(0, 0); }
    }
    @keyframes bc-glitch-cyan {
      0%   { opacity: 0;    transform: translate(0, 0); }
      25%  { opacity: 0.75; transform: translate(3px, 1px); }
      50%  { opacity: 0.8;  transform: translate(4px, -1px); }
      75%  { opacity: 0.6;  transform: translate(2px, 0); }
      100% { opacity: 0;    transform: translate(0, 0); }
    }
    @keyframes bc-glitch-shake {
      0%, 100% { transform: translate(0, 0); }
      25%      { transform: translate(-1px, 0); }
      50%      { transform: translate(1px, 0); }
      75%      { transform: translate(0, 0); }
    }

    /* ── Body ── */
    .bc-body {
      font-family: var(--poetry-mono);
      font-size: 17px;
      line-height: 1.72;
      color: var(--bc-text);
    }
    .bc-stanza {
      margin: 0 0 34px;
      font-family: var(--poetry-mono);
    }
    .bc-stanza:last-child { margin-bottom: 0; }

    .bc-callout {
      border-left: 3px solid var(--bc-red);
      background: rgba(255, 60, 40, 0.07);
      padding: 18px 20px 18px 22px;
      margin-left: -22px;
      font-family: var(--poetry-mono);
      color: var(--bc-amber);
      text-transform: uppercase;
      font-size: 15.5px;
      letter-spacing: 0.04em;
      line-height: 1.7;
    }

    /* Highlight trigger stanzas subtly, without overwhelming */
    .bc-stanza[data-trigger="desaturate"] {
      color: rgba(255, 228, 214, 0.85);
      font-style: italic;
    }
    .bc-stanza[data-trigger="resaturate"] {
      color: var(--bc-red);
      font-family: var(--poetry-display-condensed);
      font-size: clamp(34px, 5vw, 48px);
      font-weight: 700;
      text-transform: uppercase;
      line-height: 1;
      letter-spacing: 0.01em;
      margin-top: 52px;
      margin-bottom: 24px;
    }

    /* ── Footer / Next poem ── */
    .bc-footer {
      margin-top: 120px;
      padding-top: 36px;
      border-top: 1px solid rgba(255, 60, 40, 0.22);
    }
    .bc-next {
      text-decoration: none;
      display: inline-flex;
      flex-direction: column;
      gap: 8px;
      color: var(--bc-text);
      transition: color 0.2s ease;
    }
    .bc-next-label {
      font-family: var(--poetry-mono);
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--bc-red);
    }
    .bc-next-title {
      font-family: var(--poetry-classical);
      font-style: italic;
      font-weight: 500;
      font-size: clamp(22px, 3vw, 28px);
      line-height: 1.2;
      color: var(--bc-text);
    }
    .bc-next:hover .bc-next-title { color: var(--bc-red); }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .bc-article { padding: 96px var(--page-pad) 120px; }
      .bc-body { font-size: 16px; line-height: 1.7; }
      .bc-masthead { margin-bottom: 52px; }
      .bc-back { margin-bottom: 40px; }
      .bc-callout { margin-left: 0; font-size: 14.5px; }
      .bc-footer { margin-top: 80px; }
    }

    @media (prefers-reduced-motion: reduce) {
      .bc-title.is-glitching .bc-title-red,
      .bc-title.is-glitching .bc-title-cyan,
      .bc-title.is-glitching .bc-title-text { animation: none; }
      .bc-title-red, .bc-title-cyan { opacity: 0; }
      .bc-page { transition: none; }
    }
  </style>

  <script>
    const page = document.querySelector('.bc-page') as HTMLElement | null;
    const title = document.querySelector('.bc-title') as HTMLElement | null;
    const triggers = document.querySelectorAll<HTMLElement>('.bc-stanza[data-trigger]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Periodic title glitch — chromatic aberration flash every 3-5 seconds.
    if (title && !reduce) {
      const glitch = () => {
        title.classList.remove('is-glitching');
        void title.offsetWidth;
        title.classList.add('is-glitching');
        const next = 3200 + Math.random() * 2200;
        window.setTimeout(glitch, next);
      };
      window.setTimeout(glitch, 1400);
    }

    // Saturation flip — desaturate at "What if you're right?", slam back at "No."
    if (page && triggers.length && 'IntersectionObserver' in window && !reduce) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const trig = (entry.target as HTMLElement).dataset.trigger;
          if (trig === 'desaturate') page.classList.add('is-calm');
          if (trig === 'resaturate') page.classList.remove('is-calm');
        });
      }, { threshold: 0.55, rootMargin: '0px 0px -10% 0px' });
      triggers.forEach((t) => io.observe(t));
    }
  </script>
</PoetryLayout>
