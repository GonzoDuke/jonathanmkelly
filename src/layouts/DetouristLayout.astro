---
import BaseLayout from './BaseLayout.astro';

const { piece } = Astro.props;
const pageTitle = `${piece.title} — detourist`;
const ogUrl = `https://jonathanmkelly.com/detourist/${piece.id}`;
---

<BaseLayout title={pageTitle} description={piece.subtitle || ''} ogUrl={ogUrl}>
  <div style="background: #0a0a0a; min-height: 100vh;">
    <!-- Nav -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 0 var(--page-pad);
      display: flex; align-items: center; justify-content: space-between;
      height: 48px;
    `}>
      <a href="/detourist" style={`
        font-family: var(--mono); font-size: 11px; font-weight: 400;
        letter-spacing: 0.04em; color: rgba(255,255,255,0.35);
        text-decoration: none;
      `}>&larr; detourist</a>
      <span style={`
        font-family: var(--serif); font-size: 16px; font-weight: 500;
        letter-spacing: -0.01em;
      `}><span style="color: #d4822a;">de</span><span style="color: rgba(255,255,255,0.7);">tourist</span></span>
    </nav>

    <!-- Header -->
    <header style="max-width: 900px; margin: 0 auto; padding: min(14vh, 120px) var(--page-pad) 0;">
      <h1 style={`
        font-family: var(--serif); font-size: clamp(36px, 6vw, 56px);
        font-weight: 400; line-height: 1.05; color: #ffffff;
        letter-spacing: -0.02em; margin: 0 0 10px;
      `}>{piece.title}</h1>
      {piece.subtitle && (
        <p style={`
          font-family: var(--serif); font-size: 20px; font-weight: 300;
          font-style: italic; color: rgba(255,255,255,0.35); line-height: 1.35;
          margin: 0 0 32px;
        `}>{piece.subtitle}</p>
      )}
      <div style="height: 3px; background: #d4822a; width: 60px;"></div>
    </header>

    <!-- Content -->
    <main style="max-width: 900px; margin: 0 auto; padding: 44px var(--page-pad) 0;">
      <slot />
    </main>

    <!-- Footer -->
    <footer style="max-width: 900px; margin: 0 auto; padding: 80px var(--page-pad) 120px; text-align: center;">
      <div style="height: 3px; background: rgba(212,130,42,0.3); width: 60px; margin: 0 auto 32px;"></div>
      <a href="/detourist" style={`
        font-family: var(--mono); font-size: 12px; font-weight: 400;
        letter-spacing: 0.04em; color: rgba(255,255,255,0.3);
        text-decoration: none;
      `}>&larr; detourist</a>
    </footer>
  </div>
</BaseLayout>
