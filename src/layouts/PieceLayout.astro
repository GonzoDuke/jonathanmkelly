---
import BaseLayout from './BaseLayout.astro';

const { piece } = Astro.props;
const pageTitle = `${piece.title} — Jonathan M. Kelly`;
const ogUrl = `https://jonathanmkelly.com/${piece.id}`;
---

<BaseLayout title={pageTitle} description={piece.subtitle || ''} ogUrl={ogUrl}>
  <div style="background: #0f0f0f; min-height: 100vh; color: #e8e4dc;">
    <!-- Nav -->
    <nav style={`
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      background: rgba(15,15,15,0.9);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      padding: 0 var(--page-pad);
      display: flex; align-items: center; justify-content: space-between;
      height: 48px;
    `}>
      <a href="/" style={`
        font-family: var(--mono); font-size: 11px; font-weight: 400;
        letter-spacing: 0.04em; color: rgba(232,228,220,0.4);
        text-decoration: none;
      `}>&larr; Jonathan M. Kelly</a>
      <span style={`
        font-family: var(--mono); font-size: 10px; font-weight: 300;
        color: rgba(232,228,220,0.25); letter-spacing: 0.04em;
      `}>{piece.date || 'poem'}</span>
    </nav>

    <!-- Title -->
    <header style={`
      max-width: 640px; margin: 0 auto;
      padding: min(16vh, 140px) var(--page-pad) 0;
      text-align: center;
    `}>
      <h1 style={`
        font-family: var(--serif); font-size: clamp(30px, 5vw, 44px);
        font-weight: 300; line-height: 1.12; color: #e8e4dc;
        letter-spacing: -0.015em; margin: 0 0 20px;
      `}>{piece.title}</h1>
      <div style="width: 40px; height: 1px; background: rgba(232,228,220,0.2); margin: 0 auto 0;"></div>
    </header>

    <!-- Poem body -->
    <main style={`
      max-width: 600px; margin: 0 auto;
      padding: 48px var(--page-pad) 0;
    `}>
      <slot />
    </main>

    <!-- Footer -->
    <footer style={`
      max-width: 600px; margin: 0 auto;
      padding: 80px var(--page-pad) 120px; text-align: center;
    `}>
      <div style="width: 40px; height: 1px; background: rgba(232,228,220,0.1); margin: 0 auto 32px;"></div>
      <a href="/" style={`
        font-family: var(--mono); font-size: 11px; font-weight: 400;
        letter-spacing: 0.04em; color: rgba(232,228,220,0.3);
        text-decoration: none;
      `}>&larr; Back</a>
    </footer>
  </div>
</BaseLayout>
